# /etc/systemd/system/claude-secure-webhook.service
# Installed by install.sh --with-webhook (copies this file verbatim).
# Source of truth: webhook/claude-secure-webhook.service in the claude-secure repo.
#
# Directives locked by .planning/phases/14-webhook-listener/14-CONTEXT.md D-23..D-26.
# Do not add hardening (NoNewPrivileges, ProtectSystem, PrivateTmp, CapabilityBoundingSet)
# without empirical testing -- every one of those directives breaks Docker socket access
# for the `claude-secure spawn` subprocess this listener invokes. Phase 17 may revisit.

[Unit]
Description=claude-secure GitHub webhook listener
Documentation=https://github.com/llm-gourmet/claude-pod
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/claude-secure/webhook/listener.py --config __WEBHOOK_CONFIG_PATH__

# Restart policy (D-25): always restart on crash, throttle at 5s to avoid tight loops
# if the config file is broken.
Restart=always
RestartSec=5s

# Logging (D-25): listener lifecycle (startup, shutdown, crashes) goes to the journal.
# Application-level structured logs still go to ~/.claude-secure/logs/webhook.jsonl
# (written by the listener's JsonlHandler).
StandardOutput=journal
StandardError=journal
SyslogIdentifier=claude-secure-webhook

User=__WEBHOOK_USER__
Group=__WEBHOOK_GROUP__

# === D-11 (Phase 17): Safe-subset systemd hardening ===
# Each directive below was verified compatible with the listener's docker compose
# subprocess in the Phase 17 E2E test gate (D-12). See
# .planning/phases/17-operational-hardening/17-CONTEXT.md D-11 for the locked list.
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectControlGroups=true
RestrictNamespaces=true
LockPersonality=true
RestrictRealtime=true
RestrictSUIDSGID=true
MemoryDenyWriteExecute=true
SystemCallArchitectures=native

# === Hardening directives deliberately NOT added (each breaks docker compose) ===
# Phase 17 D-11/D-12 empirically re-verified this exclusion list:
#   NoNewPrivileges=true     -- blocks subprocess privilege transitions inside claude-secure
#   ProtectSystem=strict     -- Docker volume-mount machinery writes outside the allowed set
#   PrivateTmp=true          -- proxy/validator containers may touch /tmp during bootstrap
#   CapabilityBoundingSet=...-- docker daemon communication needs broader caps than predictable
#   ProtectHome=true         -- profile state lives under $HOME/.claude-secure
#   PrivateDevices=true      -- iptables validator needs /dev access on shared netns
# Re-enabling any of these without a new E2E pass will break the listener.

[Install]
WantedBy=multi-user.target
