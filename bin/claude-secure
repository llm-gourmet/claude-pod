#!/bin/bash
set -euo pipefail

CONFIG_DIR="$HOME/.claude-secure"

# Verify installation
if [ ! -f "$CONFIG_DIR/config.sh" ]; then
  echo "ERROR: claude-secure not installed. Run install.sh first." >&2
  exit 1
fi

if [ ! -f "$CONFIG_DIR/.env" ]; then
  echo "ERROR: No auth credentials found. Run install.sh first." >&2
  exit 1
fi

# Load configuration (provides APP_DIR, WORKSPACE_PATH, PLATFORM)
# shellcheck source=/dev/null
source "$CONFIG_DIR/config.sh"

# Load and auto-export auth credentials and secret env vars
# set -a makes all subsequent variable assignments exported (required for docker compose)
set -a
# shellcheck source=/dev/null
source "$CONFIG_DIR/.env"
set +a

# Set log directory for docker compose volume mount
export LOG_DIR="$CONFIG_DIR/logs"

# Set SECRETS_FILE for docker compose env_file directive (loads all secrets into proxy container)
export SECRETS_FILE="$CONFIG_DIR/.env"

# Set COMPOSE_FILE so docker compose works from any directory
export COMPOSE_FILE="$APP_DIR/docker-compose.yml"
export WORKSPACE_PATH

# Remove stale containers that docker compose can't manage
# (caused by name conflicts after unclean shutdown or compose file changes)
cleanup_containers() {
  for name in claude-proxy claude-secure claude-validator; do
    if docker inspect "$name" >/dev/null 2>&1; then
      docker rm -f "$name" >/dev/null 2>&1 || true
    fi
  done
}

# Parse log flags from arguments, export env vars for docker compose
parse_log_flags() {
  LOG_HOOK=0
  LOG_ANTHROPIC=0
  LOG_IPTABLES=0
  REMAINING_ARGS=()

  for arg in "$@"; do
    case "$arg" in
      log:hook)       LOG_HOOK=1 ;;
      log:anthropic)  LOG_ANTHROPIC=1 ;;
      log:iptables)   LOG_IPTABLES=1 ;;
      log:all)        LOG_HOOK=1; LOG_ANTHROPIC=1; LOG_IPTABLES=1 ;;
      *)              REMAINING_ARGS+=("$arg") ;;
    esac
  done

  export LOG_HOOK LOG_ANTHROPIC LOG_IPTABLES
}

# Parse log flags from all arguments
parse_log_flags "$@"

# Use first non-log-flag argument as command
CMD="${REMAINING_ARGS[0]:-}"

case "$CMD" in
  stop)
    docker compose down
    cleanup_containers
    ;;
  status)
    docker compose ps
    # Show Claude Code version if claude container is running
    if docker compose ps --status running --format '{{.Service}}' | grep -q '^claude$'; then
      echo ""
      echo "Claude Code version: $(docker compose exec -T claude claude --version 2>/dev/null || echo 'unknown')"
    fi
    ;;
  upgrade)
    echo "Upgrading Claude Code to latest version..."
    docker compose build --no-cache --pull claude
    echo ""
    echo "Upgrade complete. Restart with: claude-secure"
    ;;
  update)
    echo "Pulling latest changes..."
    cd "$APP_DIR" && git pull
    echo "Rebuilding images..."
    docker compose build
    # Update CLI wrapper if source changed
    CLI_INSTALLED="$(command -v claude-secure)"
    CLI_SOURCE="$APP_DIR/bin/claude-secure"
    if [ -f "$CLI_SOURCE" ] && ! diff -q "$CLI_SOURCE" "$CLI_INSTALLED" >/dev/null 2>&1; then
      echo "CLI wrapper changed, updating..."
      if [ -w "$(dirname "$CLI_INSTALLED")" ]; then
        cp "$CLI_SOURCE" "$CLI_INSTALLED"
        chmod 755 "$CLI_INSTALLED"
      elif command -v sudo >/dev/null 2>&1; then
        sudo cp "$CLI_SOURCE" "$CLI_INSTALLED"
        sudo chmod 755 "$CLI_INSTALLED"
      else
        echo "WARNING: Could not update CLI at $CLI_INSTALLED (no write access)"
        echo "Run manually: sudo cp $CLI_SOURCE $CLI_INSTALLED"
      fi
    fi
    echo ""
    echo "Update complete. Restart with: claude-secure"
    ;;
  logs)
    LOG_SVC="${REMAINING_ARGS[1]:-}"
    case "$LOG_SVC" in
      hook)       tail -f "$LOG_DIR/hook.jsonl" 2>/dev/null ;;
      anthropic)  tail -f "$LOG_DIR/anthropic.jsonl" 2>/dev/null ;;
      iptables)   tail -f "$LOG_DIR/iptables.jsonl" 2>/dev/null ;;
      clear)
        rm -f "$LOG_DIR"/*.jsonl
        echo "Logs cleared."
        ;;
      "")
        # Guard against unmatched glob when no .jsonl files exist yet
        shopt -s nullglob
        LOG_FILES=("$LOG_DIR"/*.jsonl)
        shopt -u nullglob
        if [ ${#LOG_FILES[@]} -eq 0 ]; then
          echo "No log files found in $LOG_DIR. Start services with log:* flags first."
          exit 0
        fi
        tail -f "${LOG_FILES[@]}"
        ;;
      *)
        echo "Unknown log service: $LOG_SVC"
        echo "Usage: claude-secure logs [hook|anthropic|iptables|clear]"
        exit 1
        ;;
    esac
    ;;
  help|--help|-h)
    echo "Usage: claude-secure [command] [log:hook] [log:anthropic] [log:iptables] [log:all]"
    echo ""
    echo "Commands:"
    echo "  (none)     Start containers and open Claude Code session"
    echo "  status     Show container status and Claude Code version"
    echo "  stop       Stop all containers"
    echo "  logs       Tail all log files (logs hook|anthropic|iptables for specific service)"
    echo "  update     Pull latest claude-secure and rebuild all images"
    echo "  upgrade    Rebuild claude image with latest Claude Code (--no-cache)"
    echo "  help       Show this help message"
    echo ""
    echo "Log flags (append to any command):"
    echo "  log:hook       Enable hook script logging"
    echo "  log:anthropic  Enable proxy logging"
    echo "  log:iptables   Enable validator/iptables logging"
    echo "  log:all        Enable all logging"
    ;;
  *)
    # Ensure log directory exists before docker compose up (pitfall 5)
    mkdir -p "$LOG_DIR"
    # 777 required: three containers write as different UIDs (claude:1001, node:1000, root:0)
    chmod 777 "$LOG_DIR"
    cleanup_containers
    docker compose up -d
    docker compose exec -it claude claude --dangerously-skip-permissions
    ;;
esac
