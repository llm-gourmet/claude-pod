#!/usr/bin/env bash
# Phase 18 PORT-02: bash 4+ re-exec guard. Apple ships bash 3.2.57 forever;
# we re-exec into brew bash 5 so the rest of this script can use bash 4+ idioms.
# This block MUST remain bash 3.2 safe (no [[ ]], no ${var,,}, no declare -A).
if [ "${BASH_VERSINFO[0]:-0}" -lt 4 ]; then
  if command -v brew >/dev/null 2>&1; then
    __brew_bash="$(brew --prefix 2>/dev/null)/bin/bash"
    if [ -x "$__brew_bash" ]; then
      exec "$__brew_bash" "$0" "$@"
    fi
  fi
  echo "ERROR: bash 4+ required. On macOS run: brew install bash" >&2
  exit 1
fi

set -euo pipefail

# Phase 18 PORT-01: source the platform library and bootstrap PATH so GNU
# coreutils (date, stat, readlink, realpath, sed, grep) shadow BSD versions
# on macOS. No-op on Linux/WSL2.
__CLAUDE_POD_SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$__CLAUDE_POD_SELF_DIR/../lib/platform.sh" ]; then
  # shellcheck source=../lib/platform.sh
  source "$__CLAUDE_POD_SELF_DIR/../lib/platform.sh"
elif [ -f "$__CLAUDE_POD_SELF_DIR/lib/platform.sh" ]; then
  # Installed layout: lib/ alongside bin/
  # shellcheck source=lib/platform.sh
  source "$__CLAUDE_POD_SELF_DIR/lib/platform.sh"
elif [ -f "/usr/local/share/claude-pod/lib/platform.sh" ]; then
  # shellcheck source=/usr/local/share/claude-pod/lib/platform.sh
  source "/usr/local/share/claude-pod/lib/platform.sh"
fi
if command -v claude_pod_bootstrap_path >/dev/null 2>&1; then
  claude_pod_bootstrap_path || true
fi

# Source-only mode: load function definitions without executing main logic.
# Used by tests: __CLAUDE_POD_SOURCE_ONLY=1 source bin/claude-pod
# (also accepts CLAUDE_POD_SOURCE_ONLY without leading underscores for the
# Phase 15 test harness)
if [ -z "${__CLAUDE_POD_SOURCE_ONLY:-}" ]; then
  __CLAUDE_POD_SOURCE_ONLY="${CLAUDE_POD_SOURCE_ONLY:-0}"
fi

CONFIG_DIR="${CONFIG_DIR:-$HOME/.claude-pod}"

# Temp files to clean up on exit (superuser mode merged configs)
_CLEANUP_FILES=()

cleanup() {
  for f in "${_CLEANUP_FILES[@]}"; do
    rm -rf "$f"
  done
}
trap cleanup EXIT

# =========================================================================
# Function definitions
# =========================================================================

validate_profile_name() {
  local name="$1"
  if [[ ! "$name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
    echo "ERROR: Profile name must be DNS-safe (lowercase alphanumeric and hyphens, must start with letter or digit)" >&2
    return 1
  fi
  if [ ${#name} -gt 63 ]; then
    echo "ERROR: Profile name must be 63 characters or less" >&2
    return 1
  fi
}

resolve_profile_dir() {
  local name="$1"
  local p="$CONFIG_DIR/profiles/$name"
  if [ -f "$p/profile.json" ]; then
    echo "$p"
    return 0
  fi
  local d="$CONFIG_DIR/docs/$name"
  if [ -f "$d/profile.json" ]; then
    echo "$d"
    return 0
  fi
  echo "$p"
}

validate_profile() {
  local name="$1"
  local pdir
  pdir=$(resolve_profile_dir "$name")

  if [ ! -d "$pdir" ]; then
    echo "ERROR: Profile '$name' does not exist at $pdir" >&2
    echo "Run: claude-pod profile create $name" >&2
    return 1
  fi
  if [ ! -f "$pdir/profile.json" ]; then
    echo "ERROR: Profile '$name' is missing profile.json" >&2
    return 1
  fi
  if ! jq empty "$pdir/profile.json" 2>/dev/null; then
    echo "ERROR: Profile '$name' has invalid profile.json (not valid JSON)" >&2
    return 1
  fi
  if [ ! -f "$pdir/.env" ]; then
    echo "ERROR: Profile '$name' is missing .env (auth credentials required)" >&2
    return 1
  fi
  local i secret
  i=0
  for secret in $(jq -c '.secrets // [] | .[]' "$pdir/profile.json" 2>/dev/null); do
    local env_var redacted domains
    env_var=$(echo "$secret" | jq -r '.env_var // empty')
    redacted=$(echo "$secret" | jq -r '.redacted // empty')
    domains=$(echo "$secret" | jq -r '.domains // empty | length')
    if [ -z "$env_var" ] || [ -z "$redacted" ] || [ "$domains" = "0" ] || [ "$domains" = "null" ]; then
      echo "ERROR: Profile '$name' secrets[$i] is missing env_var, redacted, or domains" >&2
      return 1
    fi
    i=$((i + 1))
  done
}

# Host-only secret projection: variables listed here are stripped from the
# .env copy passed to docker-compose (env_file:). Currently empty — all
# profile secrets reach the container. Kept as an extension point.
_HOST_ONLY_VARS=()

project_env_for_containers() {
  local src="$1"
  local dst
  dst=$(mktemp "${TMPDIR:-/tmp}/cs-projected-env-XXXXXXXX")
  _CLEANUP_FILES+=("$dst")
  chmod 600 "$dst"

  # Build anchored regex matching any host-only var assignment at line start.
  # Anchoring prevents substring matches like MY_DOCS_REPO_TOKEN_OVERRIDE.
  local pattern="^("
  local first=1
  local v
  for v in "${_HOST_ONLY_VARS[@]}"; do
    if [ $first -eq 1 ]; then
      pattern+="$v"
      first=0
    else
      pattern+="|$v"
    fi
  done
  pattern+=")="

  # grep -v removes matching lines. LC_ALL=C for deterministic ERE matching
  # across glibc/BSD. `|| true` because grep returns 1 if zero lines survive.
  # Also strip ANTHROPIC_BASE_URL: it is always overridden by docker-compose
  # (hardcoded to http://proxy:8080) so it must never reach the container via
  # env_file — and users often write it when they mean REAL_ANTHROPIC_BASE_URL.
  LC_ALL=C grep -Ev "$pattern" "$src" | LC_ALL=C grep -v '^ANTHROPIC_BASE_URL=' > "$dst" || true

  # Transparent remap: if ANTHROPIC_BASE_URL was present but REAL_ANTHROPIC_BASE_URL
  # was not, promote it so the proxy gets the correct upstream URL via env_file.
  if LC_ALL=C grep -q '^ANTHROPIC_BASE_URL=' "$src" && ! LC_ALL=C grep -q '^REAL_ANTHROPIC_BASE_URL=' "$src"; then
    local mapped_url
    mapped_url=$(LC_ALL=C grep '^ANTHROPIC_BASE_URL=' "$src" | head -1 | cut -d= -f2-)
    [ -n "$mapped_url" ] && printf 'REAL_ANTHROPIC_BASE_URL=%s\n' "$mapped_url" >> "$dst"
  fi

  echo "$dst"
}


create_profile() {
  local name="$1"
  local pdir="$CONFIG_DIR/profiles/$name"
  local tmpdir
  tmpdir=$(mktemp -d)
  # Register with global cleanup trap so a failed setup_profile_auth (or any
  # other abort before the atomic mv below) never leaves a half-built profile.
  _CLEANUP_FILES+=("$tmpdir")

  echo "Creating profile '$name'..."

  # Build profile.json
  jq -n '{"secrets": []}' > "$tmpdir/profile.json"

  # Scaffold system_prompts/ with a self-describing stub file.
  mkdir -p "$tmpdir/system_prompts"
  cat > "$tmpdir/system_prompts/default.md" <<EOF
# System prompt placeholder for profile '$name'

This file is a placeholder. You are reading it because no custom system prompt
has been configured yet for this profile. Please let the user know they can
customize this file at:

  ~/.claude-pod/profiles/$name/system_prompts/

Replace this content with the role, tone, and constraints for Claude in this
profile. Delete the file to omit --system-prompt entirely.
EOF

  # Auth setup
  local existing_env=""
  if [ -d "$CONFIG_DIR/profiles" ]; then
    for d in "$CONFIG_DIR/profiles"/*/; do
      if [ -f "$d/.env" ] && [ "$(cd "$d" && pwd)" != "$(cd "$tmpdir" && pwd)" ]; then
        existing_env="$d/.env"
        break
      fi
    done
  fi
  if [ -n "$existing_env" ]; then
    read -rp "Copy auth credentials from $(basename "$(dirname "$existing_env")")? [Y/n]: " copy_auth
    if [[ "${copy_auth:-y}" =~ ^[Yy]$ ]]; then
      cp "$existing_env" "$tmpdir/.env"
      echo "Auth credentials copied. Edit $pdir/.env to customize secrets."
    else
      setup_profile_auth "$tmpdir"
    fi
  else
    setup_profile_auth "$tmpdir"
  fi

  # Atomic move to final location
  mkdir -p "$(dirname "$pdir")"
  mv "$tmpdir" "$pdir"

  echo "Profile '$name' created at $pdir"
}

setup_profile_auth() {
  local dir="$1"
  # Hardened: validate non-empty, reject newline-tainted paste,
  # write .env in one grouped redirection.
  echo "Choose authentication method:"
  echo "  1) OAuth token [recommended]"
  echo "  2) API key"
  read -rp "Choice [1]: " auth_choice
  auth_choice="${auth_choice:-1}"
  local var_name value base_url=""
  case "$auth_choice" in
    2)
      read -rsp "API key: " value; echo ""
      if [ -z "$value" ]; then
        echo "ERROR: API key was empty. Profile creation aborted — no .env written." >&2
        return 1
      fi
      var_name="ANTHROPIC_API_KEY"
      echo "  Base URL (optional — leave empty for default Anthropic endpoint)"
      echo "  e.g. https://yourcompany.com/anthropic/v1"
      read -rp "Base URL [https://api.anthropic.com]: " base_url
      ;;
    *)
      echo "Run 'claude setup-token' first to get your OAuth token."
      read -rsp "OAuth token: " value; echo ""
      if [ -z "$value" ]; then
        echo "ERROR: OAuth token was empty. Profile creation aborted — no .env written." >&2
        echo "ERROR: Get your token with: claude setup-token" >&2
        return 1
      fi
      var_name="CLAUDE_CODE_OAUTH_TOKEN"
      ;;
  esac
  case "$value" in
    *$'\n'*|*$'\r'*)
      echo "ERROR: ${var_name} contains a newline or carriage return (paste buffer leakage?)." >&2
      echo "ERROR: Profile creation aborted — no .env written." >&2
      return 1
      ;;
  esac
  {
    printf '%s=%s\n' "$var_name" "$value"
    if [ -n "$base_url" ]; then
      printf 'REAL_ANTHROPIC_BASE_URL=%s\n' "$base_url"
    fi
    printf '\n'
    printf '# Add secrets below (must match env_var in profile.json secrets[])\n'
    printf '# Example: GITHUB_TOKEN=ghp_your_token_here\n'
  } > "$dir/.env"
  chmod 600 "$dir/.env"
}

resolve_profile_by_repo() {
  local target_repo="$1"
  shopt -s nullglob
  for pdir in "$CONFIG_DIR/profiles"/*/; do
    [ -f "$pdir/profile.json" ] || continue
    local repo
    repo=$(jq -r '.repo // empty' "$pdir/profile.json")
    if [ "$repo" = "$target_repo" ]; then
      basename "$pdir"
      shopt -u nullglob
      return 0
    fi
  done
  shopt -u nullglob
  echo "ERROR: No profile found for repo '$target_repo'" >&2
  return 1
}

merge_profiles() {
  local merged='{"workspace":"/workspace","secrets":[]}'
  shopt -s nullglob
  for pdir in "$CONFIG_DIR/profiles"/*/; do
    [ -f "$pdir/profile.json" ] || continue
    merged=$(echo "$merged" | jq --slurpfile p "$pdir/profile.json" '
      .secrets += ($p[0].secrets // [])
      | .secrets |= unique_by(.env_var)
    ')
  done
  shopt -u nullglob
  echo "$merged"
}

merge_env_files() {
  local merged_env
  merged_env=$(mktemp)
  shopt -s nullglob
  for pdir in "$CONFIG_DIR/profiles"/*/; do
    [ -f "$pdir/.env" ] || continue
    cat "$pdir/.env" >> "$merged_env"
    echo "" >> "$merged_env"
  done
  shopt -u nullglob
  echo "$merged_env"
}

load_profile_config() {
  local name="$1"
  local pdir
  pdir=$(resolve_profile_dir "$name")

  export COMPOSE_PROJECT_NAME="claude-${name}"
  export COMPOSE_FILE="$APP_DIR/docker-compose.yml"
  if [ -f "$pdir/.env" ]; then
    SECRETS_FILE=$(project_env_for_containers "$pdir/.env")
    export SECRETS_FILE
  else
    export SECRETS_FILE="$pdir/.env"
  fi
  CLAUDE_POD_SYSTEM_PROMPT=""
  if [ -f "$pdir/system_prompts/default.md" ]; then
    CLAUDE_POD_SYSTEM_PROMPT=$(cat "$pdir/system_prompts/default.md")
  fi
  export CLAUDE_POD_SYSTEM_PROMPT
  export PROFILE_PATH="$pdir/profile.json"
  export LOG_PREFIX="${name}-"

  # .env is required by full profile validation (`validate_profile`), but
  # spawn/replay dry-runs skip that check. Source defensively so test
  # harnesses and dry-run invocations don't fail on a missing secrets file.
  if [ -f "$pdir/.env" ]; then
    set -a +u
    # shellcheck source=/dev/null
    source "$pdir/.env"
    set +a -u
    # Transparent remap: if the user wrote ANTHROPIC_BASE_URL in .env (common
    # mistake) and REAL_ANTHROPIC_BASE_URL is not set, promote it so that
    # docker-compose variable substitution in the proxy service works correctly.
    if [ -z "${REAL_ANTHROPIC_BASE_URL:-}" ] && [ -n "${ANTHROPIC_BASE_URL:-}" ]; then
      export REAL_ANTHROPIC_BASE_URL="$ANTHROPIC_BASE_URL"
    fi
  fi
}

require_profile_arg() {
  local name="${REMAINING_ARGS[1]:-}"
  if [ -z "$name" ]; then
    echo "ERROR: <profile-name> is required" >&2
    echo "Usage: claude-pod $CMD <profile-name>" >&2
    exit 1
  fi
  validate_profile_name "$name"
  local pdir
  pdir=$(resolve_profile_dir "$name")
  if [ ! -f "$pdir/profile.json" ]; then
    echo "ERROR: profile '$name' not found. Run: claude-pod profile create $name" >&2
    exit 1
  fi
  PROFILE="$name"
  load_profile_config "$name"
}

load_superuser_config() {
  # Merge profile secrets to temp file
  local merged_wl
  merged_wl=$(mktemp)
  merge_profiles > "$merged_wl"
  _CLEANUP_FILES+=("$merged_wl")

  # Merge env files
  local merged_env
  merged_env=$(merge_env_files)
  _CLEANUP_FILES+=("$merged_env")

  export COMPOSE_PROJECT_NAME="claude-superuser"
  export COMPOSE_FILE="$APP_DIR/docker-compose.yml"
  export SECRETS_FILE="$merged_env"
  export PROFILE_PATH="$merged_wl"
  export LOG_PREFIX="superuser-"

  # Source merged env for docker compose variable substitution
  if [ -s "$merged_env" ]; then
    set -a
    # shellcheck source=/dev/null
    source "$merged_env"
    set +a
  fi
}

list_profiles() {
  printf "%-20s %-10s %s\n" "PROFILE" "STATUS" "KEYS"
  printf "%-20s %-10s %s\n" "-------" "------" "----"

  if [ ! -d "$CONFIG_DIR/profiles" ]; then
    echo "No profiles configured."
    return
  fi

  shopt -s nullglob
  local found=0
  for pdir in "$CONFIG_DIR/profiles"/*/; do
    found=1
    local name status project keys
    name=$(basename "$pdir")
    keys=$(jq -r '(.secrets // []) | length' "$pdir/profile.json" 2>/dev/null || echo "0")
    project="claude-${name}"
    if docker compose ls --format json 2>/dev/null | jq -e ".[] | select(.Name == \"$project\")" >/dev/null 2>&1; then
      status="running"
    else
      status="stopped"
    fi
    printf "%-20s %-10s %s\n" "$name" "$status" "$keys"
  done
  shopt -u nullglob

  if [ "$found" -eq 0 ]; then
    echo "No profiles configured."
  fi
}

# Issue #72: calculate human-readable running time from an ISO-8601 UTC
# timestamp (e.g. 2025-06-01T14:32:00Z) to now.
# Output: "42s", "3m 12s", "1h 5m"
calculate_running_time() {
  local started_at="$1"
  local started_ts
  started_ts=$(date -d "$started_at" +%s 2>/dev/null) || { echo "?"; return; }
  local now_ts
  now_ts=$(date -u +%s)
  local diff=$(( now_ts - started_ts ))
  if [ "$diff" -lt 0 ]; then diff=0; fi
  if [ "$diff" -lt 60 ]; then
    echo "${diff}s"
  elif [ "$diff" -lt 3600 ]; then
    local mins=$(( diff / 60 ))
    local secs=$(( diff % 60 ))
    printf "%dm %ds" "$mins" "$secs"
  else
    local hrs=$(( diff / 3600 ))
    local mins=$(( (diff % 3600) / 60 ))
    printf "%dh %dm" "$hrs" "$mins"
  fi
}

# Issue #72: list running claude-pod instances (interactive + headless) by
# querying Docker containers that carry the claude-pod.profile label.
# Docker container state IS the instance state — no separate registry needed.
list_instances() {
  local container_ids
  container_ids=$(docker ps --filter "label=claude-pod.profile" --format '{{.ID}}' 2>/dev/null) || true

  if [ -z "$container_ids" ]; then
    echo "No running instances."
    return 0
  fi

  printf "%-16s %-12s %-20s %-10s %-12s %s\n" "PROFILE" "TYPE" "STARTED" "RUNNING" "EVENT" "ID"
  printf "%-16s %-12s %-20s %-10s %-12s %s\n" "-------" "----" "-------" "-------" "-----" "--"

  while IFS= read -r cid; do
    [ -z "$cid" ] && continue
    local labels_json
    labels_json=$(docker inspect "$cid" --format '{{json .Config.Labels}}' 2>/dev/null) || continue

    local profile type event_type event_id started_at
    profile=$(printf '%s' "$labels_json" | jq -r '."claude-pod.profile" // ""')
    type=$(printf '%s' "$labels_json" | jq -r '."claude-pod.type" // ""')
    event_type=$(printf '%s' "$labels_json" | jq -r '."claude-pod.event-type" // ""')
    event_id=$(printf '%s' "$labels_json" | jq -r '."claude-pod.event-id" // ""')
    started_at=$(printf '%s' "$labels_json" | jq -r '."claude-pod.started-at" // ""')

    # Calculate running time from started-at label
    local running="?"
    if [ -n "$started_at" ] && [ "$started_at" != "null" ]; then
      running=$(calculate_running_time "$started_at")
    fi

    # Format started-at as human-readable date (YYYY-MM-DD HH:MM)
    local started_display
    if [ -n "$started_at" ] && [ "$started_at" != "null" ]; then
      started_display=$(date -d "$started_at" +"%Y-%m-%d %H:%M" 2>/dev/null || printf '%s' "$started_at")
    else
      started_display="—"
    fi

    # Use em-dash for empty event fields (interactive sessions have no event)
    if [ -z "$event_type" ] || [ "$event_type" = "null" ]; then event_type="—"; fi
    if [ -z "$event_id" ] || [ "$event_id" = "null" ]; then event_id="—"; fi

    printf "%-16s %-12s %-20s %-10s %-12s %s\n" \
      "$profile" "$type" "$started_display" "$running" "$event_type" "$event_id"
  done <<< "$container_ids"
}

cmd_profile() {
  local first="${1:-}"

  # profile create <name>
  if [ "$first" = "create" ]; then
    local prof_name="${2:-}"
    if [ -z "$prof_name" ]; then
      echo "ERROR: profile name is required" >&2
      echo "Usage: claude-pod profile create <name>" >&2
      exit 1
    fi
    validate_profile_name "$prof_name"
    local prof_dir
    prof_dir=$(resolve_profile_dir "$prof_name")
    if [ -d "$prof_dir" ] && [ -f "$prof_dir/profile.json" ]; then
      echo "Profile '$prof_name' already exists at $prof_dir"
    else
      create_profile "$prof_name"
    fi
    echo "Run 'claude-pod start $prof_name' to start a session."
    exit 0
  fi

  # profile <name> [subcommand ...]
  local prof_name="$first"
  if [ -z "$prof_name" ]; then
    echo "ERROR: profile name or 'create' is required" >&2
    echo "Usage: claude-pod profile create <name>" >&2
    echo "       claude-pod profile <name> [secret] [args...]" >&2
    exit 1
  fi
  validate_profile_name "$prof_name"
  local prof_dir
  prof_dir=$(resolve_profile_dir "$prof_name")
  if [ ! -f "$prof_dir/profile.json" ]; then
    echo "ERROR: Profile '$prof_name' not found. Run: claude-pod profile create $prof_name" >&2
    exit 1
  fi
  local subcmd="${2:-}"
  case "$subcmd" in
    secret)
      local action="${3:-}"
      case "$action" in
        add)    profile_secret_add "$prof_dir" "${@:4}" ;;
        remove) profile_secret_remove "$prof_dir" "${4:-}" ;;
        list)   profile_secret_list "$prof_dir" ;;
        "")
          echo "ERROR: Action required: add, remove, list" >&2
          echo "Usage: claude-pod profile <name> secret <add|remove|list>" >&2
          exit 1
          ;;
        *)
          echo "ERROR: Unknown action '$action'. Use: add, remove, list" >&2
          exit 1
          ;;
      esac
      ;;
    "")
      # Bare: show profile info
      local workspace secret_count running_state
      workspace=$(jq -r '.workspace // "(not set)"' "$prof_dir/profile.json" 2>/dev/null)
      secret_count=$(jq '.secrets | length' "$prof_dir/profile.json" 2>/dev/null || echo 0)
      if COMPOSE_PROJECT_NAME="claude-$prof_name" docker compose -f "$APP_DIR/docker-compose.yml" ps --status running --format '{{.Service}}' 2>/dev/null | grep -q '^claude$'; then
        running_state="running"
      else
        running_state="stopped"
      fi
      echo "Profile: $prof_name"
      echo "  Path:      $prof_dir"
      echo "  Workspace: $workspace"
      echo "  Secrets:   $secret_count configured"
      echo "  Status:    $running_state"
      ;;
    *)
      echo "ERROR: Unknown subcommand '$subcmd'. Use: secret" >&2
      exit 1
      ;;
  esac
}

profile_secret_list() {
  local pdir="$1"
  local count
  count=$(jq -r '(.secrets // []) | length' "$pdir/profile.json")
  if [ "$count" -eq 0 ]; then
    echo "No secrets configured."
    return
  fi
  printf "%-30s %-25s %s\n" "ENV_VAR" "REDACTED" "DOMAINS"
  printf "%-30s %-25s %s\n" "-------" "--------" "-------"
  jq -r '.secrets[] | [(.env_var // "-"), (.redacted // "-"), ((.domains // []) | join(","))] | @tsv' \
    "$pdir/profile.json" | while IFS=$'\t' read -r var red doms; do
    printf "%-30s %-25s %s\n" "$var" "$red" "$doms"
  done
}

profile_secret_add() {
  local pdir="$1"; shift
  local key="" value="" redacted="" domains_str=""
  local pos_count=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --redacted) redacted="$2"; shift 2 ;;
      --domains)  domains_str="$2"; shift 2 ;;
      --*)        echo "ERROR: Unknown flag: $1" >&2; return 1 ;;
      *)
        if   [ "$pos_count" -eq 0 ]; then key="$1"
        elif [ "$pos_count" -eq 1 ]; then value="$1"
        else echo "ERROR: Unexpected argument: $1" >&2; return 1
        fi
        pos_count=$((pos_count + 1))
        shift ;;
    esac
  done

  if [ -z "$key" ]; then
    echo "ERROR: env var name required (e.g. GITHUB_TOKEN)" >&2; return 1
  fi
  if [[ ! "$key" =~ ^[A-Z_][A-Z0-9_]*$ ]]; then
    echo "ERROR: Key must be an uppercase env var name (e.g. GITHUB_TOKEN)" >&2; return 1
  fi

  if [ -z "$value" ]; then
    read -rsp "Value for $key: " value; echo ""
    if [ -z "$value" ]; then
      echo "ERROR: Value was empty." >&2; return 1
    fi
  fi
  case "$value" in
    *$'\n'*|*$'\r'*)
      echo "ERROR: Value contains a newline (paste buffer leakage?)." >&2; return 1 ;;
  esac

  if [ -z "$redacted" ]; then
    redacted="REDACTED_${key}"
  fi

  local domains_json="[]"
  if [ -n "$domains_str" ]; then
    domains_json=$(printf '%s' "$domains_str" | tr ',' '\n' | jq -R . | jq -s .)
  fi

  local env_file="$pdir/.env"
  local tmp_env
  tmp_env=$(mktemp)
  if [ -f "$env_file" ]; then
    LC_ALL=C grep -v "^${key}=" "$env_file" > "$tmp_env" || true
  fi
  printf '%s=%s\n' "$key" "$value" >> "$tmp_env"
  chmod 600 "$tmp_env"
  mv "$tmp_env" "$env_file"

  local pjson="$pdir/profile.json"
  local tmp_json
  tmp_json=$(mktemp)
  jq --arg k "$key" --arg r "$redacted" --argjson d "$domains_json" \
    '.secrets = ((.secrets // []) | map(select(.env_var != $k))) + [{"env_var": $k, "redacted": $r, "domains": $d}]' \
    "$pjson" > "$tmp_json"
  mv "$tmp_json" "$pjson"

  echo "Secret '$key' added to profile."
}

profile_secret_remove() {
  local pdir="$1"
  local key="$2"

  if [ -z "$key" ]; then
    echo "ERROR: env var name required (e.g. GITHUB_TOKEN)" >&2; return 1
  fi

  local env_file="$pdir/.env"
  if [ -f "$env_file" ]; then
    local tmp_env
    tmp_env=$(mktemp)
    LC_ALL=C grep -v "^${key}=" "$env_file" > "$tmp_env" || true
    chmod 600 "$tmp_env"
    mv "$tmp_env" "$env_file"
  fi

  local pjson="$pdir/profile.json"
  local tmp_json
  tmp_json=$(mktemp)
  jq --arg k "$key" '.secrets = ((.secrets // []) | map(select(.env_var != $k)))' \
    "$pjson" > "$tmp_json"
  mv "$tmp_json" "$pjson"

  echo "Secret '$key' removed from profile."
}

# Use docker compose project-scoped cleanup instead of hardcoded names
cleanup_containers() {
  docker compose down --remove-orphans 2>/dev/null || true
}

# Parse log flags from arguments, export env vars for docker compose
parse_log_flags() {
  LOG_HOOK=0
  LOG_ANTHROPIC=0
  LOG_ANTHROPIC_BODIES=0
  LOG_IPTABLES=0
  REMAINING_ARGS=()

  for arg in "$@"; do
    case "$arg" in
      log:hook)       LOG_HOOK=1 ;;
      log:anthropic)  LOG_ANTHROPIC=1 ;;
      log:bodies)     LOG_ANTHROPIC=1; LOG_ANTHROPIC_BODIES=1 ;;
      log:iptables)   LOG_IPTABLES=1 ;;
      log:all)        LOG_HOOK=1; LOG_ANTHROPIC=1; LOG_IPTABLES=1 ;;
      *)              REMAINING_ARGS+=("$arg") ;;
    esac
  done

  export LOG_HOOK LOG_ANTHROPIC LOG_ANTHROPIC_BODIES LOG_IPTABLES
}

spawn_project_name() {
  local profile="$1"
  local uuid8
  # Pure-ASCII uuid hex, so bash parameter expansion is UTF-8 safe here.
  # (Phase 15 bans byte-based bash truncation project-wide.)
  local raw
  raw=$(uuidgen | tr -d '-' | tr '[:upper:]' '[:lower:]')
  uuid8="${raw:0:8}"
  echo "cs-${profile}-${uuid8}"
}

spawn_cleanup() {
  docker compose down -v --remove-orphans 2>/dev/null || true
  for f in "${_CLEANUP_FILES[@]}"; do
    rm -rf "$f"
  done
}

build_output_envelope() {
  local profile="$1"
  local event_type="$2"
  local claude_output="$3"
  local timestamp
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  echo "$claude_output" | jq --arg profile "$profile" \
    --arg event_type "$event_type" \
    --arg timestamp "$timestamp" \
    '{
      profile: $profile,
      event_type: $event_type,
      timestamp: $timestamp,
      claude: .
    }'
}

build_error_envelope() {
  local profile="$1"
  local event_type="$2"
  local error_msg="$3"
  local timestamp
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  jq -n --arg profile "$profile" \
    --arg event_type "$event_type" \
    --arg timestamp "$timestamp" \
    --arg error "$error_msg" \
    '{
      profile: $profile,
      event_type: $event_type,
      timestamp: $timestamp,
      error: $error
    }'
}

# =========================================================================
# Profile system-prompt resolver: the spawn system prompt is resolved from
# the profile directory (system_prompts/).
# =========================================================================

# Print the path to the system-prompt file for a given event_type in the
# current profile. Checks system_prompts/<event_type>.md, then
# system_prompts/default.md. Prints nothing and returns 0 if neither exists
# — callers treat an empty result as "omit --system-prompt".
resolve_system_prompt_file() {
  local event_type="${1:-}"
  local profile_dir
  profile_dir=$(resolve_profile_dir "$PROFILE")
  local sp_dir="$profile_dir/system_prompts"

  if [ -n "$event_type" ]; then
    local event_path="$sp_dir/${event_type}.md"
    if [ -f "$event_path" ]; then
      echo "$event_path"
      return 0
    fi
  fi

  local default_path="$sp_dir/default.md"
  if [ -f "$default_path" ]; then
    echo "$default_path"
    return 0
  fi
  return 0
}

# D-17 / D-18 / Pitfall 4: extract a jq path from an event payload and emit
# the hygienized + truncated value bytes to stdout. Hygiene strips NUL and
# ASCII control chars except \n \r \t; truncation is UTF-8-safe at 8192
# bytes with a "... [truncated N more bytes]" suffix. Uses python3 via stdin
# to avoid argv-size limits, IFS issues, and byte-unsafe bash truncation.
#
# Args:  $1 = event source (JSON string OR a path to a JSON file),
#        $2 = jq filter,
#        $3 = default when jq result is empty.
# Out:   writes the cleaned value to stdout (no temp file path indirection).
#        Callers that need a file (e.g. render_template) create their own
#        temp file via mktemp + redirection and register with _CLEANUP_FILES.
#
# Hard constraints:
#   - MUST NOT use byte-based bash truncation (unsafe for multi-byte UTF-8).
#   - MUST pass raw payload via stdin, not argv.
extract_payload_field() {
  local event_source="$1"
  local jq_path="$2"
  local default_value="${3:-}"

  # Auto-detect file vs inline JSON: a regular file on disk is read via
  # `jq -r ... <file>`, otherwise pipe the string in via a here-string.
  local raw
  if [ -f "$event_source" ]; then
    raw=$(jq -r "$jq_path // empty" "$event_source" 2>/dev/null)
  else
    raw=$(printf '%s' "$event_source" | jq -r "$jq_path // empty" 2>/dev/null)
  fi
  if [ -z "$raw" ]; then
    raw="$default_value"
  fi

  # Hygiene + truncation via python3. Payload goes through an env var (not
  # argv or stdin) to avoid heredoc/pipe collisions and argv-size limits.
  # The script itself is passed via `python3 -c` so stdin is free for the
  # caller if needed and bytes pass losslessly.
  RAW_PAYLOAD="$raw" python3 -c '
import os, sys
data = os.environb.get(b"RAW_PAYLOAD", b"")
keep = {0x09, 0x0A, 0x0D}
cleaned = bytes(b for b in data if b >= 0x20 or b in keep)
LIMIT = 8192
if len(cleaned) > LIMIT:
    truncated = cleaned[:LIMIT].decode("utf-8", errors="ignore").encode("utf-8")
    dropped = len(cleaned) - len(truncated)
    suffix = f"... [truncated {dropped} more bytes]".encode("utf-8")
    cleaned = truncated + suffix
sys.stdout.buffer.write(cleaned)
'
}

# Helper: extract a field (via extract_payload_field) into a new temp file,
# register with _CLEANUP_FILES, and echo the temp file path. Used by
# render_template to feed _substitute_token_from_file.
_extract_to_tempfile() {
  local event_source="$1"
  local jq_path="$2"
  local default_value="${3:-}"
  local out_file
  out_file=$(mktemp)
  _CLEANUP_FILES+=("$out_file")
  extract_payload_field "$event_source" "$jq_path" "$default_value" > "$out_file"
  echo "$out_file"
}

# Phase 16 D-08: report-template fallback chain.
# Clone of resolve_template for report templates. Only the subdir names
# change (prompts/ -> report-templates/, templates/ -> report-templates/).
# There is no explicit-override flag for reports: the report template is
# chosen purely by event_type.
resolve_report_template() {
  local event_type="$1"

  local profile_dir
  profile_dir=$(resolve_profile_dir "$PROFILE")
  local reports_dir="$profile_dir/report-templates"
  local docs_reports_dir="$CONFIG_DIR/docs/$PROFILE/report-templates"

  # Step 1: profile override by event_type (profiles/ dir).
  if [ -d "$reports_dir" ]; then
    local path="$reports_dir/${event_type}.md"
    if [ -f "$path" ]; then
      echo "$path"
      return 0
    fi
  fi

  # Step 1b: docs/ fallback for profile report templates.
  if [ -d "$docs_reports_dir" ]; then
    local path="$docs_reports_dir/${event_type}.md"
    if [ -f "$path" ]; then
      echo "$path"
      return 0
    fi
  fi

  # Step 2: default template fallback (via parameterized resolver).
  local default_dir
  default_dir=$(_resolve_default_templates_dir "report-templates")
  if [ -d "$default_dir" ]; then
    local path="$default_dir/${event_type}.md"
    if [ -f "$path" ]; then
      echo "$path"
      return 0
    fi
  fi

  # Step 3: hard fail, listing every path checked.
  echo "ERROR: No report template found for event_type '$event_type'" >&2
  echo "  Checked: $reports_dir/${event_type}.md" >&2
  echo "  Checked: $docs_reports_dir/${event_type}.md" >&2
  echo "  Checked: $default_dir/${event_type}.md" >&2
  echo "  Create one of the above to enable report publishing." >&2
  return 1
}

# =========================================================================
# Phase 16 helpers (D-04..D-18): result text extraction, report rendering,
# secret redaction, audit log writer, publish + push retry.
# =========================================================================

# Phase 16 D-16 / Pitfall 4: extract .claude.result from the envelope and
# emit the UTF-8-safe, control-char-stripped, 16KB-truncated bytes to a
# fresh tempfile. Dedicated variant (vs extract_payload_field) so the
# Phase 15 8KB payload limit stays unchanged for prompt rendering.
_extract_result_text_to_tempfile() {
  local envelope_source="$1"
  local out_file
  out_file=$(mktemp)
  _CLEANUP_FILES+=("$out_file")

  local raw
  if [ -f "$envelope_source" ]; then
    raw=$(jq -r '.claude.result // empty' "$envelope_source" 2>/dev/null)
  else
    raw=$(printf '%s' "$envelope_source" | jq -r '.claude.result // empty' 2>/dev/null)
  fi

  RAW_PAYLOAD="$raw" python3 -c '
import os, sys
data = os.environb.get(b"RAW_PAYLOAD", b"")
keep = {0x09, 0x0A, 0x0D}
cleaned = bytes(b for b in data if b >= 0x20 or b in keep)
LIMIT = 16384
if len(cleaned) > LIMIT:
    truncated = cleaned[:LIMIT].decode("utf-8", errors="ignore").encode("utf-8")
    dropped = len(cleaned) - len(truncated)
    suffix = f"... [truncated {dropped} more bytes]".encode("utf-8")
    cleaned = truncated + suffix
sys.stdout.buffer.write(cleaned)
' > "$out_file"

  echo "$out_file"
}

# Phase 16 D-10 / D-11 / Pattern G / Pitfall 2: render a report template.
# Chains on top of Phase 15's render_template (which substitutes all D-16
# variables using the awk-from-file pattern) then substitutes the six
# D-10 extension variables. RESULT_TEXT and ERROR_MESSAGE are deliberately
# LAST so embedded {{ISSUE_TITLE}} style tokens inside Claude's output
# are not re-interpreted as template variables (Pitfall 2).
render_report_template() {
  local template_path="$1"
  local event_json="$2"
  local envelope_json="$3"
  local status="$4"

  # Step 1: run Phase 15 render_template to substitute all D-16 variables.
  local rendered
  rendered=$(render_template "$template_path" "$event_json")
  local v_file

  # Step 2: substitute D-10 metadata variables (short single-line) FIRST,
  # so that if RESULT_TEXT contains e.g. {{COST_USD}}, the inner token
  # survives the RESULT_TEXT substitution (which runs last).
  #
  # Pitfall 5: cost_usd // cost and duration_ms // duration fallback
  # because Claude Code has shipped both field names historically.
  v_file=$(_extract_to_tempfile "$envelope_json" '.claude.cost_usd // .claude.cost // 0 | tostring' "0")
  rendered=$(_substitute_token_from_file "$rendered" "COST_USD" "$v_file")

  v_file=$(_extract_to_tempfile "$envelope_json" '.claude.duration_ms // .claude.duration // 0 | tostring' "0")
  rendered=$(_substitute_token_from_file "$rendered" "DURATION_MS" "$v_file")

  v_file=$(_extract_to_tempfile "$envelope_json" '.claude.session_id // ""' "")
  rendered=$(_substitute_token_from_file "$rendered" "SESSION_ID" "$v_file")

  # Wrapper-generated: TIMESTAMP and STATUS come from the caller, not the envelope.
  v_file=$(mktemp); _CLEANUP_FILES+=("$v_file")
  date -u +"%Y-%m-%dT%H:%M:%SZ" > "$v_file"
  rendered=$(_substitute_token_from_file "$rendered" "TIMESTAMP" "$v_file")

  v_file=$(mktemp); _CLEANUP_FILES+=("$v_file")
  printf '%s' "$status" > "$v_file"
  rendered=$(_substitute_token_from_file "$rendered" "STATUS" "$v_file")

  # Step 3: LAST — RESULT_TEXT and ERROR_MESSAGE.
  # These carry arbitrary Claude output that may contain literal {{TOKEN}}
  # strings. Substituting them AFTER all other passes guarantees those
  # literal tokens are preserved (Pitfall 2).
  v_file=$(_extract_result_text_to_tempfile "$envelope_json")
  rendered=$(_substitute_multiline_token_from_file "$rendered" "RESULT_TEXT" "$v_file")

  v_file=$(_extract_to_tempfile "$envelope_json" '.error // ""' "")
  rendered=$(_substitute_multiline_token_from_file "$rendered" "ERROR_MESSAGE" "$v_file")

  printf '%s' "$rendered"
}

# Phase 24 RPT-01: validate that a rendered report body contains all 6
# mandatory H2 sections from webhook/report-templates/bundle.md. Anchored
# regex (^## Section$) prevents partial matches inside code blocks or
# headings like "## Goal Achievements".
#
# Caller (Phase 26 Stop hook) is responsible for re-prompting Claude if a
# report is malformed. Phase 24 ships the validator only.
#
# Args:
#   $1 = body_path  (path to rendered report markdown)
# Returns:
#   0 if all 6 sections present
#   1 if any are missing (stderr lists every missing section)
verify_bundle_sections() {
  local body_path="$1"
  if [ ! -f "$body_path" ]; then
    echo "ERROR: verify_bundle_sections: file not found: $body_path" >&2
    return 1
  fi

  local _required=(
    "^## Goal$"
    "^## Where Worked$"
    "^## What Changed$"
    "^## What Failed$"
    "^## How to Test$"
    "^## Future Findings$"
  )
  local section missing=0
  for section in "${_required[@]}"; do
    if ! LC_ALL=C grep -qE "$section" "$body_path"; then
      echo "ERROR: report missing mandatory section: ${section#^## }" | sed 's/\$$//' >&2
      missing=1
    fi
  done
  if [ "$missing" -ne 0 ]; then
    return 1
  fi
  return 0
}

# Phase 24 RPT-04: strip markdown constructs that can exfiltrate data.
#
# Order matters: HTML comments first (they can hide <img> beacons), then
# raw HTML tags, then external image references (inline + reference-style).
#
# Local image references (relative paths, ./img.png, img/foo.svg) are
# PRESERVED because they cannot exfiltrate (no DNS, no external fetch).
#
#
# Uses GNU sed semantics. On macOS, Phase 18 PORT-01 PATH-shims gnubin so
# `sed` is GNU sed even on Darwin.
#
# Args:
#   $1 = path  (file is edited in place)
# Returns:
#   0 always (no-op on missing constructs is fine)
#   1 only if the file does not exist
sanitize_markdown_file() {
  local f="$1"
  if [ ! -f "$f" ]; then
    return 1
  fi

  local tmp
  tmp=$(mktemp "${TMPDIR:-/tmp}/cs-sanitize-XXXXXXXX")
  _CLEANUP_FILES+=("$tmp")

  # Pass 1: strip HTML comments (multi-line). The :a; N; $!ba; idiom slurps
  # the entire file into pattern space so multi-line <!-- ... --> matches.
  # The non-greedy approximation [^-]|-[^-]|--[^>] is the canonical POSIX
  # workaround for sed's lack of PCRE lazy quantifiers.
  LC_ALL=C sed -E \
    -e ':a' -e 'N' -e '$!ba' \
    -e 's/<!--([^-]|-[^-]|--[^>])*-->//g' \
    "$f" > "$tmp" && mv "$tmp" "$f"

  # Pass 2: strip raw HTML tags (opening, closing, self-closing). Aggressive
  # by design — the bundle template is plain markdown and any user-agent-
  # interpreted HTML is a potential beacon.
  LC_ALL=C sed -E -i.bak 's|</?[A-Za-z][A-Za-z0-9-]*[^>]*>||g' "$f"
  rm -f "$f.bak"

  # Pass 3: strip external inline image references.
  # Matches: ![alt](http://...) | ![alt](https://...) | ![alt](//...)
  # Does NOT match: ![alt](./local.png), ![alt](img/foo.svg)
  # NOTE: Uses '#' as the s-command delimiter because the regex's alternation
  # '(https?:|//)' contains literal '|' — using '|' as a sed delimiter here
  # terminates the substitution early ("unknown option to `s'" error).
  LC_ALL=C sed -E -i.bak 's#!\[[^]]*\]\((https?:|//)[^)]*\)##g' "$f"
  rm -f "$f.bak"

  # Pass 4: strip reference-style image definitions pointing at external URLs.
  # Matches: [ref]: https://... | [ref]: http://... | [ref]: //...
  # Deletes the entire line (GFM image references are line-anchored).
  LC_ALL=C sed -E -i.bak '/^\[[^]]+\]:[[:space:]]+(https?:|\/\/)/d' "$f"
  rm -f "$f.bak"

  return 0
}

# Phase 16 D-15 / Pattern B / Pitfall 1: redact every non-empty profile
# .env value from a rendered report file in place. Uses awk-from-file
# LITERAL substring replace (index + substr) so any value metacharacter
# (| / \ & $ [ ] ^ * .) is safe. NEVER uses sed with interpolation.
redact_report_file() {
  local report_file="$1"
  local env_file="$2"
  local tmp_out tmp_val
  tmp_out=$(mktemp)
  tmp_val=$(mktemp)
  _CLEANUP_FILES+=("$tmp_out" "$tmp_val")

  while IFS='=' read -r raw_key raw_val || [ -n "$raw_key" ]; do
    [[ -z "$raw_key" || "$raw_key" =~ ^[[:space:]]*# ]] && continue
    raw_key="${raw_key#export }"
    raw_key="${raw_key//[[:space:]]/}"
    [ -z "$raw_key" ] && continue
    raw_val="${raw_val%$'\r'}"
    raw_val="${raw_val#\"}"; raw_val="${raw_val%\"}"
    raw_val="${raw_val#\'}"; raw_val="${raw_val%\'}"
    # D-15: skip empty values
    [ -z "$raw_val" ] && continue

    printf '%s' "$raw_val" > "$tmp_val"

    awk -v repl="<REDACTED:${raw_key}>" -v vfile="$tmp_val" '
      BEGIN {
        value = ""
        first = 1
        while ((getline line < vfile) > 0) {
          if (first) { value = line; first = 0 }
          else       { value = value "\n" line }
        }
        close(vfile)
        if (value == "") exit 0
      }
      {
        line = $0
        out = ""
        while ((i = index(line, value)) > 0) {
          out = out substr(line, 1, i-1) repl
          line = substr(line, i + length(value))
        }
        print out line
      }
    ' "$report_file" > "$tmp_out"
    mv "$tmp_out" "$report_file"
    : > "$tmp_val"
  done < "$env_file"

  rm -f "$tmp_val" 2>/dev/null || true
}

# Phase 16 D-04 / D-06 / D-07 / Pattern C / Pitfall 8 / Pitfall 14:
# Append a single audit line to $LOG_DIR/${LOG_PREFIX}executions.jsonl.
# Uses jq -cn for safe JSON construction. Enforces a 4095-byte guard so
# POSIX O_APPEND atomicity (< PIPE_BUF = 4096 on Linux) is preserved under
# concurrent same-profile spawns (Phase 14 semaphore up to 3).
write_audit_entry() {
  local ts="$1" delivery_id="$2" webhook_id="$3" event_type="$4"
  local profile="$5" repo="$6" commit_sha="$7" branch="$8"
  local cost_usd="$9" duration_ms="${10}" session_id="${11}"
  local status="${12}" report_url="${13}" error_short="${14:-}"

  local _audit_log_dir="${CONFIG_DIR}/logs"
  mkdir -p "$_audit_log_dir"
  local audit_file="$_audit_log_dir/${LOG_PREFIX:-}executions.jsonl"

  # jq_cost / jq_duration normalize: "" -> null, numeric -> number.
  local jq_cost="null" jq_duration="null"
  [ -n "$cost_usd" ] && jq_cost="$cost_usd"
  [ -n "$duration_ms" ] && jq_duration="$duration_ms"

  local line
  line=$(jq -cn \
    --arg ts "$ts" \
    --arg delivery_id "$delivery_id" \
    --arg webhook_id "$webhook_id" \
    --arg event_type "$event_type" \
    --arg profile "$profile" \
    --arg repo "$repo" \
    --arg commit_sha "$commit_sha" \
    --arg branch "$branch" \
    --arg session_id "$session_id" \
    --arg status "$status" \
    --arg report_url "$report_url" \
    --arg error_short "$error_short" \
    --argjson cost_usd "$jq_cost" \
    --argjson duration_ms "$jq_duration" \
    '{
      ts: $ts,
      delivery_id: $delivery_id,
      webhook_id: (if $webhook_id == "" then null else $webhook_id end),
      event_type: $event_type,
      profile: $profile,
      repo: (if $repo == "" then null else $repo end),
      commit_sha: (if $commit_sha == "" then null else $commit_sha end),
      branch: (if $branch == "" then null else $branch end),
      cost_usd: $cost_usd,
      duration_ms: $duration_ms,
      session_id: (if $session_id == "" then null else $session_id end),
      status: $status,
      report_url: (if $report_url == "" then null else $report_url end),
      error_short: (if $error_short == "" then null else $error_short end)
    }')

  # Pattern C / Pitfall 14: refuse to emit over-budget lines; drop error_short
  # and retry once with a sentinel value.
  if [ "${#line}" -gt 4095 ]; then
    echo "WARNING: audit line exceeds PIPE_BUF, dropping error_short" >&2
    line=$(jq -cn \
      --arg ts "$ts" --arg delivery_id "$delivery_id" --arg webhook_id "$webhook_id" \
      --arg event_type "$event_type" --arg profile "$profile" --arg repo "$repo" \
      --arg commit_sha "$commit_sha" --arg branch "$branch" \
      --arg session_id "$session_id" --arg status "$status" --arg report_url "$report_url" \
      --argjson cost_usd "$jq_cost" --argjson duration_ms "$jq_duration" \
      '{
        ts: $ts, delivery_id: $delivery_id,
        webhook_id: (if $webhook_id == "" then null else $webhook_id end),
        event_type: $event_type, profile: $profile,
        repo: (if $repo == "" then null else $repo end),
        commit_sha: (if $commit_sha == "" then null else $commit_sha end),
        branch: (if $branch == "" then null else $branch end),
        cost_usd: $cost_usd, duration_ms: $duration_ms,
        session_id: (if $session_id == "" then null else $session_id end),
        status: $status,
        report_url: (if $report_url == "" then null else $report_url end),
        error_short: "<dropped: over-budget>"
      }')
  fi

  printf '%s\n' "$line" >> "$audit_file"
}

# Phase 16: best-effort audit writer for early-return spawn_error paths.
# Called from do_spawn precondition checks before delivery_id/event_type
# are known. Uses synthetic manual-<uuid> and "unknown" event_type.
_spawn_error_audit() {
  local err_msg="$1"
  local _ts _did
  _ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  _did="manual-$(uuidgen 2>/dev/null | tr -d - | head -c 32 || echo unknown)"
  write_audit_entry "$_ts" "$_did" "" "unknown" "${PROFILE:-unknown}" \
    "" "" "" "" "" "" "spawn_error" "" "${err_msg:0:200}" 2>/dev/null || true
}

do_spawn() {
  # Help check before profile guard so `spawn --help` works without a profile name
  for _arg in "${REMAINING_ARGS[@]}"; do
    if [ "$_arg" = "--help" ] || [ "$_arg" = "-h" ]; then
      echo "Usage: claude-pod spawn <name> --event '<json>'"
      echo ""
      echo "Spawn flags:"
      echo "  --event '<json>'       Inline GitHub webhook event JSON"
      echo "  --event-file <path>    Path to event JSON file"
      echo "  --prompt-template <n>  Override automatic template resolution"
      echo "  --dry-run              Show resolved prompt without executing"
      return 0
    fi
  done

  # Extract profile name from positional arg (REMAINING_ARGS[1]) if not pre-set.
  # PROFILE may be pre-set by do_replay or tests (legacy path); in that case config
  # is already loaded externally and flags start at index 1.
  local _spawn_args_offset=1
  if [ -z "${PROFILE:-}" ]; then
    local _candidate="${REMAINING_ARGS[1]:-}"
    if [ -n "$_candidate" ] && [[ "$_candidate" != --* ]]; then
      # First arg is a profile name (not a flag)
      PROFILE="$_candidate"
      _spawn_args_offset=2
      validate_profile_name "$PROFILE" || return 1
      local _spawn_pdir
      _spawn_pdir=$(resolve_profile_dir "$PROFILE")
      if [ ! -f "$_spawn_pdir/profile.json" ]; then
        echo "ERROR: profile '$PROFILE' not found. Run: claude-pod profile create $PROFILE" >&2
        _spawn_error_audit "spawn: profile '$PROFILE' not found"
        return 1
      fi
      load_profile_config "$PROFILE"
    fi
  fi
  if [ -z "${PROFILE:-}" ]; then
    echo "ERROR: profile name is required for spawn" >&2
    echo "Usage: claude-pod spawn <name> --event '<json>'" >&2
    _spawn_error_audit "spawn: profile name is required"
    return 1
  fi

  # Parse spawn-specific flags from REMAINING_ARGS (skip "spawn" + optional profile name)
  EVENT_JSON=""
  EVENT_FILE=""
  PROMPT_TEMPLATE=""
  DRY_RUN=0
  local i=$_spawn_args_offset
  while [ $i -lt ${#REMAINING_ARGS[@]} ]; do
    case "${REMAINING_ARGS[$i]:-}" in
      --event)          EVENT_JSON="${REMAINING_ARGS[$((i+1))]:-}"; i=$((i+2)) ;;
      --event-file)     EVENT_FILE="${REMAINING_ARGS[$((i+1))]:-}"; i=$((i+2)) ;;
      --prompt-template) PROMPT_TEMPLATE="${REMAINING_ARGS[$((i+1))]:-}"; i=$((i+2)) ;;
      --dry-run)        DRY_RUN=1; i=$((i+1)) ;;
      *)                i=$((i+1)) ;;
    esac
  done

  # Load event from file if --event-file used (per D-02)
  if [ -n "$EVENT_FILE" ] && [ -z "$EVENT_JSON" ]; then
    if [ ! -f "$EVENT_FILE" ]; then
      echo "ERROR: Event file not found: $EVENT_FILE" >&2
      _spawn_error_audit "spawn: event file not found: $EVENT_FILE"
      return 1
    fi
    EVENT_JSON=$(cat "$EVENT_FILE")
  fi

  # Validate event JSON is provided and valid
  if [ -z "$EVENT_JSON" ]; then
    echo "ERROR: --event or --event-file is required for spawn" >&2
    echo "Usage: claude-pod spawn <name> --event '<json>'" >&2
    _spawn_error_audit "spawn: --event or --event-file is required"
    return 1
  fi
  if ! echo "$EVENT_JSON" | jq empty 2>/dev/null; then
    echo "ERROR: Invalid JSON in --event" >&2
    _spawn_error_audit "spawn: invalid JSON in --event"
    return 1
  fi

  # Generate ephemeral project name (per D-05)
  COMPOSE_PROJECT_NAME=$(spawn_project_name "$PROFILE")
  export COMPOSE_PROJECT_NAME

  # Set cleanup trap (per D-07) - overrides the default cleanup trap
  trap spawn_cleanup EXIT

  # Extract event_type from event JSON for envelope
  local event_type
  # D-03: Priority: top-level .event_type (Phase 15) > ._meta.event_type (Phase 14) > .action (older)
  event_type=$(echo "$EVENT_JSON" | jq -r '.event_type // ._meta.event_type // .action // "unknown"')

  # Phase 16 / D-12: derive delivery_id.
  # Priority: ._meta.delivery_id (webhook path) > replay-<uuid> (CLAUDE_POD_EXEC set) > manual-<uuid>.
  local delivery_id webhook_id delivery_id_short _did_stripped
  delivery_id=$(echo "$EVENT_JSON" | jq -r '._meta.delivery_id // empty')
  if [ -z "$delivery_id" ]; then
    if [ -n "${CLAUDE_POD_EXEC:-}" ]; then
      delivery_id="replay-$(uuidgen 2>/dev/null | tr -d - | head -c 32 || echo unknown)"
    else
      delivery_id="manual-$(uuidgen 2>/dev/null | tr -d - | head -c 32 || echo unknown)"
    fi
    webhook_id=""
  else
    webhook_id="$delivery_id"
  fi
  # D-12: delivery_id_short = last 8 chars of the *stripped* id (no replay-/manual- prefix).
  _did_stripped="${delivery_id##*-}"
  delivery_id_short="${_did_stripped: -8}"

  # Phase 16 / D-06: audit metadata extracted from event JSON.
  local audit_repo audit_commit audit_branch
  audit_repo=$(echo "$EVENT_JSON" | jq -r '.repository.full_name // empty')
  audit_commit=$(echo "$EVENT_JSON" | jq -r '.pull_request.head.sha // .after // .head_commit.id // empty')
  audit_branch=$(echo "$EVENT_JSON" | jq -r '.pull_request.head.ref // (.ref // empty | sub("^refs/heads/"; ""))')
  [ "$audit_branch" = "null" ] && audit_branch=""

  # Hardcoded human-turn prompt for headless (spawn) mode.
  # The full event payload is appended below.
  local rendered_prompt
  rendered_prompt="Review the event payload and follow the instructions in the system prompt."

  if [ -n "${EVENT_JSON:-}" ]; then
    rendered_prompt+="

---
Event Payload (\`${event_type}\`):
\`\`\`json
${EVENT_JSON}
\`\`\`"
  fi

  # Resolve system prompt file (may be empty = omit --system-prompt).
  local system_prompt_file system_prompt_source="none"
  system_prompt_file=$(resolve_system_prompt_file "$event_type")
  if [ -n "$system_prompt_file" ]; then
    CLAUDE_POD_SYSTEM_PROMPT=$(cat "$system_prompt_file")
    system_prompt_source="$system_prompt_file"
  else
    CLAUDE_POD_SYSTEM_PROMPT=""
  fi
  export CLAUDE_POD_SYSTEM_PROMPT

  # --dry-run: print resolved paths + content and exit.
  if [ "$DRY_RUN" -eq 1 ]; then
    echo "system_prompt: $system_prompt_source"
    echo "---"
    echo "$rendered_prompt"
    return 0
  fi

  # Build claude command flags
  # NOTE: --bare is intentionally OMITTED. Per RESEARCH.md Open Question 3,
  # --bare skips hooks/CLAUDE.md/MCP. The PreToolUse security hooks inside the
  # container are critical for enforcing the security whitelist (CLAUDE.md mandate).
  # Until empirical testing confirms hooks survive --bare, we do NOT use it.
  # The small startup time cost is acceptable vs risking security bypass.
  local claude_args=("$rendered_prompt" "--output-format" "json" "--dangerously-skip-permissions")
  if [ -n "${CLAUDE_POD_SYSTEM_PROMPT:-}" ]; then
    claude_args+=("--system-prompt" "$CLAUDE_POD_SYSTEM_PROMPT")
  fi

  # Issue #72: compute event-id from event payload for Docker label.
  # event-id identifies the specific event that triggered this spawn:
  #   push        → first 7 chars of commit SHA (Pure-ASCII hex, byte truncation safe)
  #   issues/issue_comment → "#<number>"
  #   pull_request/pull_request_review_comment → "#<number>"
  #   workflow_run → run ID (numeric string)
  local _spawn_event_id=""
  case "$event_type" in
    push)
      local _sha
      _sha=$(printf '%s' "$EVENT_JSON" | jq -r '.after // .head_commit.id // ""')
      # Pure-ASCII SHA hex — byte-based truncation is safe here.
      if [ ${#_sha} -ge 7 ]; then _spawn_event_id="${_sha:0:7}"; fi
      ;;
    issues|issue_comment)
      _spawn_event_id=$(printf '%s' "$EVENT_JSON" | jq -r '(.issue.number // empty | if . then "#\(.)" else "" end)' 2>/dev/null || true)
      ;;
    pull_request|pull_request_review_comment)
      _spawn_event_id=$(printf '%s' "$EVENT_JSON" | jq -r '(.pull_request.number // empty | if . then "#\(.)" else "" end)' 2>/dev/null || true)
      ;;
    workflow_run)
      _spawn_event_id=$(printf '%s' "$EVENT_JSON" | jq -r '(.workflow_run.id // empty | if . then tostring else "" end)' 2>/dev/null || true)
      ;;
  esac

  # Issue #72: set Docker labels before docker compose up so running instances
  # are discoverable via `docker ps --filter label=claude-pod.profile`.
  export CLAUDE_POD_LABEL_PROFILE="${PROFILE:-}"
  export CLAUDE_POD_LABEL_TYPE="headless"
  export CLAUDE_POD_LABEL_EVENT_TYPE="${event_type:-}"
  export CLAUDE_POD_LABEL_EVENT_ID="${_spawn_event_id:-}"
  export CLAUDE_POD_LABEL_STARTED_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  # Execute headless Claude Code (per D-06, D-09)
  local claude_stdout claude_stderr_file claude_exit=0
  claude_stderr_file=$(mktemp)
  _CLEANUP_FILES+=("$claude_stderr_file")

  # Phase 16 test escape hatch: if CLAUDE_POD_FAKE_CLAUDE_STDOUT points at a
  # file, skip docker and use its contents as the envelope stdout. Mirrors the
  # Phase 15 CLAUDE_POD_EXEC pattern. Production path unchanged.
  if [ -n "${CLAUDE_POD_FAKE_CLAUDE_STDOUT:-}" ] && [ -f "${CLAUDE_POD_FAKE_CLAUDE_STDOUT}" ]; then
    claude_stdout=$(cat "${CLAUDE_POD_FAKE_CLAUDE_STDOUT}")
    claude_exit="${CLAUDE_POD_FAKE_CLAUDE_EXIT:-0}"
  else
    docker compose up -d --wait
    claude_stdout=$(docker compose exec -T claude claude -p "${claude_args[@]}" < /dev/null 2>"$claude_stderr_file") || claude_exit=$?
  fi

  # Validate Claude output contains expected fields (per HEAD-02: result, cost, duration, session_id)
  # Note: Exact field names from --output-format json are documented as result, session_id,
  # cost_usd/cost, duration_ms/duration. Log actual fields for debugging if validation fails.
  if [ "$claude_exit" -eq 0 ]; then
    local has_result
    has_result=$(echo "$claude_stdout" | jq 'has("result")' 2>/dev/null)
    if [ "$has_result" != "true" ]; then
      echo "WARNING: Claude output missing expected 'result' field. Actual keys: $(echo "$claude_stdout" | jq -r 'keys | join(", ")' 2>/dev/null)" >&2
      echo "DEBUG: Raw output fields: $(echo "$claude_stdout" | jq -r 'keys[]' 2>/dev/null | tr '\n' ' ')" >&2
    fi
  fi

  local envelope_json audit_status
  local _audit_ts _audit_duration_total _audit_cost _audit_session _audit_err_short=""
  _audit_ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  if [ "$claude_exit" -eq 0 ]; then
    envelope_json=$(build_output_envelope "$PROFILE" "$event_type" "$claude_stdout")
    audit_status="success"
  else
    local error_msg stderr_msg
    stderr_msg=$(cat "$claude_stderr_file" 2>/dev/null || echo "")
    # Claude Code writes auth/startup errors to stdout, not stderr — combine both.
    if [ -n "$stderr_msg" ]; then
      error_msg="$stderr_msg"
    elif [ -n "$claude_stdout" ]; then
      error_msg="$claude_stdout"
    else
      error_msg=""
    fi
    envelope_json=$(build_error_envelope "$PROFILE" "$event_type" "$error_msg")
    audit_status="claude_error"
    _audit_err_short="${error_msg:0:200}"
  fi

  # Extract audit fields from envelope (Pitfall 5: legacy cost/duration fallback).
  _audit_cost=$(echo "$envelope_json" | jq -r '.claude.cost_usd // .claude.cost // 0' 2>/dev/null || echo 0)
  _audit_duration_total=$(echo "$envelope_json" | jq -r '.claude.duration_ms // .claude.duration // 0' 2>/dev/null || echo 0)
  _audit_session=$(echo "$envelope_json" | jq -r '.claude.session_id // ""' 2>/dev/null || echo "")

  # D-17: audit-always.
  write_audit_entry \
    "$_audit_ts" \
    "$delivery_id" \
    "$webhook_id" \
    "$event_type" \
    "$PROFILE" \
    "$audit_repo" \
    "$audit_commit" \
    "$audit_branch" \
    "$_audit_cost" \
    "$_audit_duration_total" \
    "$_audit_session" \
    "$audit_status" \
    "" \
    "$_audit_err_short" 2>/dev/null || true

  # Emit envelope to stdout.
  echo "$envelope_json"

  return "$claude_exit"
}

# =========================================================================
# D-20 .. D-22: `replay <delivery-id>` subcommand (HOOK-07).
#
# Accepts a delivery-id substring, finds the matching persisted event file
# under $CONFIG_DIR/events/, auto-resolves the profile via
# resolve_profile_by_repo (unless --profile is explicit), and exec-s itself
# with spawn --event-file. Using exec instead of inlining do_spawn avoids
# duplicating the spawn lifecycle.
# =========================================================================
do_replay() {
  local delivery_substring=""
  local explicit_profile=""
  local dry_run=0

  # Parse REMAINING_ARGS. Index 0 is "replay".
  # Positional args: first is profile name, second is delivery-id substring.
  # If only one positional given, treat as delivery-id and auto-detect profile.
  local _positionals=()
  local i=1
  while [ $i -lt ${#REMAINING_ARGS[@]} ]; do
    case "${REMAINING_ARGS[$i]:-}" in
      --dry-run)
        dry_run=1
        i=$((i+1))
        ;;
      --*)
        i=$((i+1))
        ;;
      *)
        _positionals+=("${REMAINING_ARGS[$i]}")
        i=$((i+1))
        ;;
    esac
  done

  if [ "${#_positionals[@]}" -ge 2 ]; then
    explicit_profile="${_positionals[0]}"
    delivery_substring="${_positionals[1]}"
  elif [ "${#_positionals[@]}" -eq 1 ]; then
    delivery_substring="${_positionals[0]}"
  fi

  if [ -z "$delivery_substring" ]; then
    echo "ERROR: replay requires a delivery-id substring" >&2
    echo "Usage: claude-pod replay <name> <delivery-id> [--dry-run]" >&2
    return 1
  fi

  local events_dir="$CONFIG_DIR/events"
  if [ ! -d "$events_dir" ]; then
    echo "ERROR: events directory not found: $events_dir" >&2
    return 1
  fi

  local matches=()
  shopt -s nullglob
  for f in "$events_dir"/*"${delivery_substring}"*.json; do
    matches+=("$f")
  done
  shopt -u nullglob

  if [ ${#matches[@]} -eq 0 ]; then
    echo "ERROR: no event file matching '$delivery_substring' in $events_dir" >&2
    return 1
  fi
  if [ ${#matches[@]} -gt 1 ]; then
    echo "ERROR: multiple event files match '$delivery_substring':" >&2
    local m
    for m in "${matches[@]}"; do
      echo "  $m" >&2
    done
    echo "Narrow the substring and retry." >&2
    return 1
  fi

  local event_file="${matches[0]}"

  # D-21: auto-resolve profile from repository.full_name when --profile not
  # explicitly passed on this replay invocation.
  if [ -z "$explicit_profile" ]; then
    local repo
    repo=$(jq -r '.repository.full_name // empty' "$event_file")
    if [ -z "$repo" ]; then
      echo "ERROR: cannot determine repository from $event_file -- pass profile name: claude-pod replay <name> <delivery-id>" >&2
      return 1
    fi
    explicit_profile=$(resolve_profile_by_repo "$repo") || return 1
  fi

  echo "Replaying $event_file as profile '$explicit_profile'..."

  # D-20 / Pattern 9: exec recursively into claude-pod so we reuse
  # do_spawn without duplicating its lifecycle. Test harnesses that invoke
  # REAL claude-pod directly (by full path) may set CLAUDE_POD_EXEC
  # to point at a stub binary so the exec target is recorded rather than
  # running the full spawn path. Falls back to `$0` when unset.
  local exec_target="${CLAUDE_POD_EXEC:-$0}"
  local args=(spawn "$explicit_profile" --event-file "$event_file")
  if [ "$dry_run" = 1 ]; then
    args+=(--dry-run)
  fi
  exec "$exec_target" "${args[@]}"
}

# =========================================================================
# Phase 17: Reaper (OPS-03)
# Cleans up orphaned spawn containers + stale event files. Invoked via the
# `reap` subcommand or the claude-pod-reaper.timer systemd unit.
# Locked by .planning/phases/17-operational-hardening/17-CONTEXT.md D-01..D-12.
# =========================================================================

# D-04 / D-05 / D-07: orphan detection + teardown.
# Walks every compose project whose name begins with the instance prefix and
# whose first container is older than REAPER_ORPHAN_AGE_SECS. For each,
# runs `docker compose -p <project> down -v --remove-orphans --timeout 10`.
#
# Returns the kill count via the global REAPED_COUNT, errors via REAPED_ERRORS.
reap_orphan_projects() {
  local prefix="${1:-${INSTANCE_PREFIX:-cs-}}"
  local age_threshold="${REAPER_ORPHAN_AGE_SECS:-600}"
  local now killed=0 errors=0
  now=$(date +%s)

  # docker --filter does NOT support glob; we filter by label key existence
  # and apply the prefix match in bash. The label key is fixed; we collect
  # unique project values and prefix-match in shell.
  local projects
  projects=$(docker ps -a \
               --filter "label=com.docker.compose.project" \
               --format '{{.Label "com.docker.compose.project"}}' \
             2>/dev/null | sort -u)

  local proj
  while IFS= read -r proj; do
    [ -z "$proj" ] && continue
    # Multi-instance (D-07): only touch projects matching this prefix.
    case "$proj" in
      "$prefix"*) ;;
      *) continue ;;
    esac

    # Defensive shape guard: spawn projects follow cs-<profile>-<8hex>.
    # Refuses to reap other compose stacks that happen to share the prefix.
    case "$proj" in
      cs-*-*) ;;
      *) continue ;;
    esac

    # Get the project's oldest container Created timestamp via docker inspect.
    local first_id created created_epoch age
    first_id=$(docker ps -a \
                 --filter "label=com.docker.compose.project=$proj" \
                 --format '{{.ID}}' 2>/dev/null \
               | head -1)
    # Under mocked docker (tests), docker ps with a value filter may return
    # empty; fall back to the project name as an inspect key just so the
    # mock's inspect branch still fires. In production the first_id path
    # always succeeds because docker ps returns real container IDs.
    [ -z "$first_id" ] && first_id="$proj"

    created=$(docker inspect --format '{{.Created}}' "$first_id" 2>/dev/null)
    if [ -z "$created" ]; then
      echo "reaper: ERROR cannot read Created for $proj" >&2
      errors=$((errors + 1))
      continue
    fi

    # Strip ISO8601 fractional seconds for portable `date -d` parsing.
    # Some inputs have .123456789Z (strip fractional), others just Z; handle both.
    local created_clean="$created"
    case "$created_clean" in
      *.*Z) created_clean="${created_clean%.*}Z" ;;
      *.*)  created_clean="${created_clean%.*}" ;;
    esac
    created_epoch=$(date -d "$created_clean" +%s 2>/dev/null) || {
      echo "reaper: ERROR cannot parse Created=$created for $proj" >&2
      errors=$((errors + 1))
      continue
    }
    age=$((now - created_epoch))

    if [ "$age" -lt "$age_threshold" ]; then
      continue  # too young, skip
    fi

    if [ "${REAPER_DRY_RUN:-0}" = "1" ]; then
      echo "reaper: [dry-run] would reap $proj age=${age}s"
      killed=$((killed + 1))
      continue
    fi

    echo "reaper: reaped $proj age=${age}s"
    if docker compose -p "$proj" down -v --remove-orphans --rmi local --timeout 10 \
         >/dev/null 2>&1; then
      killed=$((killed + 1))
    else
      echo "reaper: ERROR tearing down $proj" >&2
      errors=$((errors + 1))
    fi
  done <<< "$projects"

  REAPED_COUNT=$killed
  REAPED_ERRORS=$errors
}

# D-06 / Phase 14 D-20 fold-in: delete event files older than REAPER_EVENT_AGE_SECS.
# Pure age-based; no audit cross-reference. Default threshold 86400s = 24h.
reap_stale_event_files() {
  local events_dir="${CONFIG_DIR:-$HOME/.claude-pod}/events"
  local age_secs="${REAPER_EVENT_AGE_SECS:-86400}"
  local age_mins=$((age_secs / 60))

  EVENTS_DELETED=0
  [ -d "$events_dir" ] || return 0

  # find -mmin +N matches files strictly older than N minutes.
  local deleted=0 f
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    if [ "${REAPER_DRY_RUN:-0}" = "1" ]; then
      echo "reaper: [dry-run] would delete $f"
      deleted=$((deleted + 1))
      continue
    fi
    if rm -f -- "$f" 2>/dev/null; then
      deleted=$((deleted + 1))
    fi
  done < <(find "$events_dir" -maxdepth 1 -type f -name '*.json' -mmin "+$age_mins" 2>/dev/null)

  EVENTS_DELETED=$deleted
}

# D-08 (Phase 18 PORT-03): single-flight reaper cycle. Uses mkdir-based atomic
# locking with a PID file for stale-lock reclaim. Replaces the previous flock
# primitive which is util-linux-only and not available on macOS without an
# extra brew formula. mkdir is atomic on every POSIX filesystem.
do_reap() {
  local dry_run=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1; shift ;;
      --help|-h)
        echo "Usage: claude-pod reap [--dry-run]"
        echo "  Cleans up orphaned spawn containers and stale event files."
        return 0
        ;;
      *)
        echo "reaper: unknown flag '$1'" >&2
        echo "Usage: claude-pod reap [--dry-run]" >&2
        return 2
        ;;
    esac
  done
  export REAPER_DRY_RUN=$dry_run

  # Phase 18 PORT-03: mkdir-based atomic lock with PID file.
  local lockdir="${LOG_DIR:-$CONFIG_DIR/logs}/${LOG_PREFIX:-}reaper.lockdir"
  local pidfile="$lockdir/pid"
  mkdir -p "$(dirname "$lockdir")" 2>/dev/null || true

  if ! mkdir "$lockdir" 2>/dev/null; then
    # Lockdir already exists — check holder liveness
    local holder_pid=0
    if [ -r "$pidfile" ]; then
      holder_pid="$(cat "$pidfile" 2>/dev/null || echo 0)"
    fi
    if [ "${holder_pid:-0}" -gt 0 ] && kill -0 "$holder_pid" 2>/dev/null; then
      echo "reaper: another instance is running (pid=$holder_pid lockdir=$lockdir), skipping cycle"
      return 0
    fi
    # Stale: holder is dead. Reclaim.
    echo "reaper: stale lockdir found (dead holder pid=$holder_pid), reclaiming"
    rm -f "$pidfile" 2>/dev/null || true
    rmdir "$lockdir" 2>/dev/null || true
    if ! mkdir "$lockdir" 2>/dev/null; then
      echo "reaper: failed to acquire lockdir after reclaim attempt, skipping cycle"
      return 0
    fi
  fi
  echo "$$" > "$pidfile" 2>/dev/null || true
  # Cleanup on any exit path (normal return, error, signal)
  # shellcheck disable=SC2064
  trap "rm -f '$pidfile' 2>/dev/null || true; rmdir '$lockdir' 2>/dev/null || true" EXIT

  echo "reaper: cycle start prefix=${INSTANCE_PREFIX:-cs-}"

  REAPED_COUNT=0
  REAPED_ERRORS=0
  EVENTS_DELETED=0

  reap_orphan_projects "${INSTANCE_PREFIX:-cs-}"
  reap_stale_event_files

  echo "reaper: cycle end killed=${REAPED_COUNT} events_deleted=${EVENTS_DELETED} errors=${REAPED_ERRORS}"

  # D-10: whole-cycle failure (all projects errored, none reaped) flips exit code.
  if [ "${REAPED_ERRORS:-0}" -gt 0 ] && [ "${REAPED_COUNT:-0}" -eq 0 ]; then
    return 1
  fi
  return 0
}

# =========================================================================
# bootstrap-docs: scaffold project documentation in a remote git repo
# =========================================================================

_bootstrap_docs_connections_file() {
  echo "$CONFIG_DIR/docs-bootstrap/connections.json"
}

_bootstrap_docs_read_connections() {
  local f; f=$(_bootstrap_docs_connections_file)
  if [ ! -f "$f" ]; then echo "[]"; return 0; fi
  cat "$f"
}

_bootstrap_docs_write_connections() {
  local json="$1"
  local dir="$CONFIG_DIR/docs-bootstrap"
  local f="$dir/connections.json"
  if [ ! -d "$dir" ]; then mkdir -p "$dir"; chmod 700 "$dir"; fi
  local tmp; tmp=$(mktemp "$dir/connections.XXXXXXXX.json")
  printf '%s\n' "$json" > "$tmp"
  mv "$tmp" "$f"
  chmod 600 "$f"
}

_bootstrap_docs_find_connection() {
  local name="$1"
  local connections; connections=$(_bootstrap_docs_read_connections)
  local conn; conn=$(printf '%s' "$connections" | jq -r --arg n "$name" '.[] | select(.name == $n) | @json' 2>/dev/null | head -1)
  if [ -z "$conn" ]; then
    echo "Error: connection '$name' not found. Run --list-connections to see available connections." >&2
    return 1
  fi
  echo "$conn"
}

# Resolve the templates directory from the user config dir.
_bootstrap_docs_find_templates() {
  local templates_dir="${CONFIG_DIR}/docs-templates"
  if [ -d "$templates_dir" ]; then
    echo "$templates_dir"
  else
    echo "Error: bootstrap-docs templates not found at $templates_dir. Re-run install.sh to restore them." >&2
    return 1
  fi
}

# Scaffold the standard project folder structure at $1 inside the repo at $2.
_bootstrap_docs_scaffold() {
  local target_path="$1" repo_dir="$2" templates_dir="$3"
  local project_dir="$repo_dir/$target_path"

  mkdir -p "$project_dir"
  cp -r "$templates_dir/." "$project_dir/"
}

cmd_bootstrap_docs() {
  local path_arg="" connection_name=""
  local add_connection=0 remove_connection="" list_connections=0
  local conn_name="" conn_repo="" conn_token="" conn_branch=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --add-connection)    add_connection=1;           shift ;;
      --remove-connection) remove_connection="$2";     shift 2 ;;
      --list-connections)  list_connections=1;         shift ;;
      --connection)        connection_name="$2";       shift 2 ;;
      --name)              conn_name="$2";             shift 2 ;;
      --repo)              conn_repo="$2";             shift 2 ;;
      --token)             conn_token="$2";            shift 2 ;;
      --branch)            conn_branch="$2";           shift 2 ;;
      --help|-h)
        echo "Usage: claude-pod bootstrap-docs --connection <name> <path>"
        echo "       claude-pod bootstrap-docs --add-connection --name <n> --repo <url> --token <t> [--branch <b>]"
        echo "       claude-pod bootstrap-docs --remove-connection <name>"
        echo "       claude-pod bootstrap-docs --list-connections"
        echo ""
        echo "Scaffold project documentation at <path> in the named connection's docs repo."
        echo "<path> is relative to the repo root, e.g. projects/JAD or custom/myproject"
        return 0
        ;;
      -*) echo "Error: unknown flag '$1'" >&2; return 1 ;;
      *)  path_arg="$1"; shift ;;
    esac
  done

  # --add-connection
  if [ "$add_connection" -eq 1 ]; then
    if [ -z "$conn_name" ] || [ -z "$conn_repo" ] || [ -z "$conn_token" ]; then
      echo "Error: --add-connection requires --name, --repo, and --token" >&2
      return 1
    fi
    conn_branch="${conn_branch:-main}"
    local connections; connections=$(_bootstrap_docs_read_connections)
    local existing; existing=$(printf '%s' "$connections" | jq -r --arg n "$conn_name" '.[] | select(.name == $n) | .name' 2>/dev/null)
    if [ -n "$existing" ]; then
      echo "Error: connection '$conn_name' already exists" >&2
      return 1
    fi
    local new_conn; new_conn=$(jq -n --arg n "$conn_name" --arg r "$conn_repo" \
      --arg t "$conn_token" --arg b "$conn_branch" '{name:$n,repo:$r,token:$t,branch:$b}')
    local updated; updated=$(printf '%s' "$connections" | jq --argjson c "$new_conn" '. + [$c]')
    _bootstrap_docs_write_connections "$updated"
    echo "Added connection '$conn_name'"
    return 0
  fi

  # --remove-connection
  if [ -n "$remove_connection" ]; then
    local connections; connections=$(_bootstrap_docs_read_connections)
    local existing; existing=$(printf '%s' "$connections" | jq -r --arg n "$remove_connection" '.[] | select(.name == $n) | .name' 2>/dev/null)
    if [ -z "$existing" ]; then
      echo "Error: connection '$remove_connection' not found" >&2
      return 1
    fi
    local updated; updated=$(printf '%s' "$connections" | jq --arg n "$remove_connection" '[.[] | select(.name != $n)]')
    _bootstrap_docs_write_connections "$updated"
    echo "Removed connection '$remove_connection'"
    return 0
  fi

  # --list-connections
  if [ "$list_connections" -eq 1 ]; then
    local connections; connections=$(_bootstrap_docs_read_connections)
    local count; count=$(printf '%s' "$connections" | jq 'length' 2>/dev/null)
    if [ "${count:-0}" -eq 0 ]; then
      echo "No connections configured."
      return 0
    fi
    printf '%s' "$connections" | jq -r '.[] | "\(.name)  \(.repo)  \(.branch // "main")"'
    return 0
  fi

  # Bootstrap action: --connection required
  if [ -z "$connection_name" ]; then
    echo "Error: --connection <name> is required" >&2
    echo "Run 'claude-pod bootstrap-docs --list-connections' to see available connections." >&2
    return 1
  fi

  if [ -z "$path_arg" ]; then
    echo "Usage: claude-pod bootstrap-docs --connection <name> <path>" >&2
    echo "Run 'claude-pod bootstrap-docs --help' for more information." >&2
    return 1
  fi

  local conn_json; conn_json=$(_bootstrap_docs_find_connection "$connection_name") || return 1
  local repo_url; repo_url=$(printf '%s' "$conn_json" | jq -r '.repo')
  local branch; branch=$(printf '%s' "$conn_json" | jq -r '.branch // "main"')
  local pat; pat=$(printf '%s' "$conn_json" | jq -r '.token // ""')

  local clone_dir
  clone_dir=$(mktemp -d "${TMPDIR:-/tmp}/cs-bootstrap-XXXXXXXX")
  _CLEANUP_FILES+=("$clone_dir")

  # Ephemeral ASKPASS helper (Pattern A — same as publish_report).
  local askpass="$clone_dir/.askpass.sh"
  cat > "$askpass" <<'ASKPASS'
#!/bin/sh
case "$1" in
  Username*) printf 'x-access-token\n' ;;
  Password*) printf '%s\n' "$GIT_ASKPASS_PAT" ;;
esac
ASKPASS
  chmod 700 "$askpass"

  echo "Cloning $repo_url (branch: $branch)..."
  local clone_err="$clone_dir/clone.err"
  if ! LC_ALL=C \
       GIT_ASKPASS="$askpass" \
       GIT_ASKPASS_PAT="$pat" \
       GIT_TERMINAL_PROMPT=0 \
       GIT_HTTP_LOW_SPEED_LIMIT=1 \
       GIT_HTTP_LOW_SPEED_TIME=30 \
       timeout 60 \
       git -c credential.helper= -c credential.helper='' \
           -c core.autocrlf=false \
           clone --depth 1 --branch "$branch" --quiet "$repo_url" "$clone_dir/repo" \
           2>"$clone_err"; then
    sed "s|${pat}|<REDACTED:DOCS_BOOTSTRAP_TOKEN>|g" "$clone_err" >&2
    echo "Error: clone failed" >&2
    return 1
  fi

  local repo_dir="$clone_dir/repo"

  if [ -d "$repo_dir/$path_arg" ] || [ -f "$repo_dir/$path_arg" ]; then
    echo "Error: $path_arg already exists in remote repo" >&2
    return 1
  fi

  local templates_dir
  templates_dir=$(_bootstrap_docs_find_templates) || return 1

  echo "Scaffolding $path_arg..."
  _bootstrap_docs_scaffold "$path_arg" "$repo_dir" "$templates_dir"

  if ! LC_ALL=C \
       GIT_AUTHOR_NAME="claude-pod" \
       GIT_AUTHOR_EMAIL="claude-pod@localhost" \
       GIT_COMMITTER_NAME="claude-pod" \
       GIT_COMMITTER_EMAIL="claude-pod@localhost" \
       git -C "$repo_dir" -c core.autocrlf=false add "$path_arg"; then
    echo "Error: git add failed" >&2
    return 1
  fi

  if ! LC_ALL=C \
       GIT_AUTHOR_NAME="claude-pod" \
       GIT_AUTHOR_EMAIL="claude-pod@localhost" \
       GIT_COMMITTER_NAME="claude-pod" \
       GIT_COMMITTER_EMAIL="claude-pod@localhost" \
       git -C "$repo_dir" -c core.autocrlf=false commit -q -m "bootstrap: $path_arg"; then
    echo "Error: git commit failed" >&2
    return 1
  fi

  local push_err="$clone_dir/push.err"
  if ! LC_ALL=C \
       GIT_ASKPASS="$askpass" \
       GIT_ASKPASS_PAT="$pat" \
       GIT_TERMINAL_PROMPT=0 \
       git -C "$repo_dir" -c credential.helper= -c credential.helper='' \
           push origin "$branch" 2>"$push_err"; then
    sed "s|${pat}|<REDACTED:DOCS_BOOTSTRAP_TOKEN>|g" "$push_err" >&2
    echo "Error: push failed" >&2
    return 1
  fi

  echo "Done. $path_arg bootstrapped in $repo_url"
}

# =========================================================================
# webhook-connections: manage ~/.claude-pod/webhooks/connections.json
# =========================================================================

_webhook_connections_file() {
  echo "$CONFIG_DIR/webhooks/connections.json"
}

_webhook_read_connections() {
  local f; f=$(_webhook_connections_file)
  if [ ! -f "$f" ]; then echo "[]"; return 0; fi
  cat "$f"
}

_webhook_write_connections() {
  local json="$1"
  local dir="$CONFIG_DIR/webhooks"
  local f="$dir/connections.json"
  if [ ! -d "$dir" ]; then mkdir -p "$dir"; chmod 700 "$dir"; fi
  local tmp; tmp=$(mktemp "$dir/connections.XXXXXXXX.json")
  printf '%s\n' "$json" > "$tmp"
  mv "$tmp" "$f"
  chmod 600 "$f"
}

_webhook_find_connection() {
  local name="$1"
  local connections; connections=$(_webhook_read_connections)
  local conn; conn=$(printf '%s' "$connections" | jq -r --arg n "$name" '.[] | select(.name == $n) | @json' 2>/dev/null | head -1)
  if [ -z "$conn" ]; then
    echo "Error: connection '$name' not found. Run --list-connections to see available connections." >&2
    return 1
  fi
  echo "$conn"
}

# =========================================================================
# gh-webhook-listener filter subcommands
# =========================================================================

_gh_webhook_filter_coverage() {
  echo "  push events          → commit message prefix"
  echo "  pr/issues/discussion → label match"
  echo "  comments/reviews     → body prefix"
  echo "  workflow/check/etc   → not applicable (no free-text field)"
}

_gh_webhook_filter_add() {
  local value="" conn_name=""
  value="${1:-}"; shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) conn_name="$2"; shift 2 ;;
      *) echo "Error: unknown argument '$1'" >&2; return 1 ;;
    esac
  done

  if [ -z "$value" ] || [ -z "$conn_name" ]; then
    echo "Error: filter add requires a value and --name <connection>" >&2
    return 1
  fi

  local connections; connections=$(_webhook_read_connections)
  local existing; existing=$(printf '%s' "$connections" | jq -r --arg n "$conn_name" \
    '.[] | select(.name == $n) | .name' 2>/dev/null)
  if [ -z "$existing" ]; then
    echo "Error: connection '$conn_name' not found" >&2
    return 1
  fi

  local dup; dup=$(printf '%s' "$connections" | jq -r --arg n "$conn_name" --arg v "$value" \
    '.[] | select(.name == $n) | .skip_filters // [] | .[] | select(. == $v)' 2>/dev/null)
  if [ -n "$dup" ]; then
    echo "Error: filter '$value' already exists on connection '$conn_name'" >&2
    return 1
  fi

  local updated; updated=$(printf '%s' "$connections" | jq \
    --arg n "$conn_name" --arg v "$value" \
    '[.[] | if .name == $n then .skip_filters = ((.skip_filters // []) + [$v]) else . end]')
  _webhook_write_connections "$updated"
  echo "Filter \"$value\" added to connection \"$conn_name\":"
  _gh_webhook_filter_coverage
  return 0
}

_gh_webhook_filter_list() {
  local conn_name=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) conn_name="$2"; shift 2 ;;
      *) echo "Error: unknown argument '$1'" >&2; return 1 ;;
    esac
  done

  if [ -z "$conn_name" ]; then
    echo "Error: --name <connection> is required" >&2
    return 1
  fi

  local connections; connections=$(_webhook_read_connections)
  local existing; existing=$(printf '%s' "$connections" | jq -r --arg n "$conn_name" \
    '.[] | select(.name == $n) | .name' 2>/dev/null)
  if [ -z "$existing" ]; then
    echo "Error: connection '$conn_name' not found" >&2
    return 1
  fi

  local filters; filters=$(printf '%s' "$connections" | jq -r --arg n "$conn_name" \
    '.[] | select(.name == $n) | .skip_filters // [] | .[]' 2>/dev/null)

  if [ -z "$filters" ]; then
    echo "No filters configured for connection '$conn_name'."
    return 0
  fi

  while IFS= read -r fv; do
    echo "Filter \"$fv\":"
    _gh_webhook_filter_coverage
    echo ""
  done <<< "$filters"
  return 0
}

_gh_webhook_filter_remove() {
  local value="" conn_name=""
  value="${1:-}"; shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) conn_name="$2"; shift 2 ;;
      *) echo "Error: unknown argument '$1'" >&2; return 1 ;;
    esac
  done

  if [ -z "$value" ] || [ -z "$conn_name" ]; then
    echo "Error: filter remove requires a value and --name <connection>" >&2
    return 1
  fi

  local connections; connections=$(_webhook_read_connections)
  local existing; existing=$(printf '%s' "$connections" | jq -r --arg n "$conn_name" \
    '.[] | select(.name == $n) | .name' 2>/dev/null)
  if [ -z "$existing" ]; then
    echo "Error: connection '$conn_name' not found" >&2
    return 1
  fi

  local existing_fv; existing_fv=$(printf '%s' "$connections" | jq -r \
    --arg n "$conn_name" --arg v "$value" \
    '.[] | select(.name == $n) | .skip_filters // [] | .[] | select(. == $v)' 2>/dev/null)
  if [ -z "$existing_fv" ]; then
    echo "Error: filter '$value' not found on connection '$conn_name'" >&2
    return 1
  fi

  local updated; updated=$(printf '%s' "$connections" | jq \
    --arg n "$conn_name" --arg v "$value" \
    '[.[] | if .name == $n then .skip_filters = [(.skip_filters // [])[] | select(. != $v)] else . end]')
  _webhook_write_connections "$updated"
  echo "Removed filter '$value' from connection '$conn_name'"
  return 0
}

cmd_gh_webhook_filter() {
  local subcmd="${1:-}"
  shift || true
  case "$subcmd" in
    add)    _gh_webhook_filter_add "$@" ;;
    list)   _gh_webhook_filter_list "$@" ;;
    remove) _gh_webhook_filter_remove "$@" ;;
    *)
      echo "Usage: claude-pod gh-webhook-listener filter <add|list|remove> ..." >&2
      echo "  filter add \"<value>\" --name <connection>" >&2
      echo "  filter list --name <connection>" >&2
      echo "  filter remove \"<value>\" --name <connection>" >&2
      return 1
      ;;
  esac
}

# =========================================================================
# gh-webhook-listener: configure and inspect the webhook listener service
# =========================================================================

# Show status of the webhook listener service.
_gh_webhook_listener_status() {
  local webhook_json="${WEBHOOK_CONFIG:-$HOME/.claude-pod/webhooks/webhook.json}"

  if [ ! -r "$webhook_json" ]; then
    echo "No listener configured. Run claude-pod gh-webhook-listener --help"
    return 0
  fi

  local bind port
  bind=$(jq -r '.bind // "127.0.0.1"' "$webhook_json" 2>/dev/null || echo "127.0.0.1")
  port=$(jq -r '.port // 9000' "$webhook_json" 2>/dev/null || echo "9000")
  bind="${bind:-127.0.0.1}"
  port="${port:-9000}"

  local systemd_status="unknown"
  if command -v systemctl >/dev/null 2>&1; then
    systemd_status=$(systemctl is-active claude-pod-webhook 2>/dev/null || echo "inactive")
  fi

  local health_status="unreachable"
  local health_response
  if health_response=$(curl -sf --max-time 3 "http://${bind}:${port}/health" 2>/dev/null); then
    health_status=$(echo "$health_response" | jq -r '.status // "unknown"' 2>/dev/null || echo "unknown")
  fi

  echo "Webhook Listener Status"
  echo "  Bind:     ${bind}:${port}"
  echo "  Systemd:  $systemd_status"
  echo "  Health:   $health_status"

  if [ "$health_status" != "ok" ] || [ "$systemd_status" != "active" ]; then
    return 1
  fi
  return 0
}

# Atomic jq write to webhook.json: _webhook_json_set_key <file> <key> <value> [--argjson]
_webhook_json_set_key() {
  local file="$1" key="$2" value="$3" numflag="${4:-}"
  mkdir -p "$(dirname "$file")"
  local src="{}"
  [ -f "$file" ] && src=$(cat "$file")
  local tmp
  tmp=$(mktemp)
  if [ "$numflag" = "--argjson" ]; then
    echo "$src" | jq --argjson v "$value" --arg k "$key" '.[$k] = $v' > "$tmp"
  else
    echo "$src" | jq --arg v "$value" --arg k "$key" '.[$k] = $v' > "$tmp"
  fi
  mv "$tmp" "$file"
  chmod 600 "$file"
}

cmd_gh_webhook_listener() {
  local set_token="" set_bind="" set_port="" set_profile="" conn_name=""
  local add_connection=0 remove_connection="" list_connections=0
  local conn_repo="" conn_secret="" conn_profile=""
  local subcmd=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --set-token)         set_token="$2";         shift 2 ;;
      --set-bind)          set_bind="$2";           shift 2 ;;
      --set-port)          set_port="$2";           shift 2 ;;
      --set-profile)       set_profile="$2";        shift 2 ;;
      --name)              conn_name="$2";          shift 2 ;;
      --profile)           conn_profile="$2";       shift 2 ;;
      --add-connection)    add_connection=1;        shift ;;
      --remove-connection) remove_connection="$2";  shift 2 ;;
      --list-connections)  list_connections=1;      shift ;;
      --repo)              conn_repo="$2";          shift 2 ;;
      --webhook-secret)    conn_secret="$2";        shift 2 ;;
      --help|-h)
        echo "Usage: claude-pod gh-webhook-listener [subcommand]"
        echo "       claude-pod gh-webhook-listener --add-connection --name <n> --repo <r> --webhook-secret <s> [--profile <p>]"
        echo "       claude-pod gh-webhook-listener --remove-connection <name>"
        echo "       claude-pod gh-webhook-listener --list-connections"
        echo "       claude-pod gh-webhook-listener --set-profile <profile> --name <name>"
        echo "       claude-pod gh-webhook-listener --set-bind <addr>"
        echo "       claude-pod gh-webhook-listener --set-port <port>"
        echo "       claude-pod gh-webhook-listener status"
        echo "       claude-pod gh-webhook-listener filter add \"<value>\" --name <connection>"
        echo "       claude-pod gh-webhook-listener filter list --name <connection>"
        echo "       claude-pod gh-webhook-listener filter remove \"<value>\" --name <connection>"
        echo ""
        echo "Connections are stored in ~/.claude-pod/webhooks/connections.json."
        echo "Bind/port are persisted to ~/.claude-pod/webhooks/webhook.json."
        return 0
        ;;
      filter) shift; cmd_gh_webhook_filter "$@"; return $? ;;
      status) subcmd="status"; shift ;;
      -*) echo "Error: unknown flag '$1'" >&2; return 1 ;;
      *) subcmd="$1"; shift ;;
    esac
  done

  local WEBHOOK_JSON="${WEBHOOK_CONFIG:-$HOME/.claude-pod/webhooks/webhook.json}"

  # --add-connection
  if [ "$add_connection" -eq 1 ]; then
    if [ -z "$conn_name" ] || [ -z "$conn_repo" ] || [ -z "$conn_secret" ]; then
      echo "Error: --add-connection requires --name, --repo, and --webhook-secret" >&2
      return 1
    fi
    local connections; connections=$(_webhook_read_connections)
    local existing; existing=$(printf '%s' "$connections" | jq -r --arg n "$conn_name" '.[] | select(.name == $n) | .name' 2>/dev/null)
    if [ -n "$existing" ]; then
      echo "Error: connection '$conn_name' already exists" >&2
      return 1
    fi
    local new_conn; new_conn=$(jq -n --arg n "$conn_name" --arg r "$conn_repo" \
      --arg s "$conn_secret" '{name:$n,repo:$r,webhook_secret:$s}')
    if [ -n "$conn_profile" ]; then
      new_conn=$(printf '%s' "$new_conn" | jq --arg p "$conn_profile" '. + {profile:$p}')
    fi
    local updated; updated=$(printf '%s' "$connections" | jq --argjson c "$new_conn" '. + [$c]')
    _webhook_write_connections "$updated"
    echo "Added connection '$conn_name'"
    return 0
  fi

  # --remove-connection
  if [ -n "$remove_connection" ]; then
    local connections; connections=$(_webhook_read_connections)
    local existing; existing=$(printf '%s' "$connections" | jq -r --arg n "$remove_connection" '.[] | select(.name == $n) | .name' 2>/dev/null)
    if [ -z "$existing" ]; then
      echo "Error: connection '$remove_connection' not found" >&2
      return 1
    fi
    local updated; updated=$(printf '%s' "$connections" | jq --arg n "$remove_connection" '[.[] | select(.name != $n)]')
    _webhook_write_connections "$updated"
    echo "Removed connection '$remove_connection'"
    return 0
  fi

  # --list-connections
  if [ "$list_connections" -eq 1 ]; then
    local connections; connections=$(_webhook_read_connections)
    local count; count=$(printf '%s' "$connections" | jq 'length' 2>/dev/null)
    if [ "${count:-0}" -eq 0 ]; then
      echo "No connections configured."
      return 0
    fi
    printf '%s' "$connections" | jq -r '.[] | "\(.name)  \(.repo)" + (if .profile and .profile != .name then "  (profile: \(.profile))" else "" end)'
    return 0
  fi

  # --set-profile
  if [ -n "$set_profile" ]; then
    if [ -z "$conn_name" ]; then
      echo "Error: --name <name> is required with --set-profile" >&2
      return 1
    fi
    local connections; connections=$(_webhook_read_connections)
    local existing; existing=$(printf '%s' "$connections" | jq -r --arg n "$conn_name" '.[] | select(.name == $n) | .name' 2>/dev/null)
    if [ -z "$existing" ]; then
      echo "Error: connection '$conn_name' not found" >&2
      return 1
    fi
    local updated; updated=$(printf '%s' "$connections" | jq --arg n "$conn_name" --arg p "$set_profile" \
      '[.[] | if .name == $n then .profile = $p else . end]')
    _webhook_write_connections "$updated"
    echo "Set profile='$set_profile' for connection '$conn_name'"
    return 0
  fi

  # --set-token
  if [ -n "$set_token" ]; then
    if [ -z "$conn_name" ]; then
      echo "Error: --name <name> is required with --set-token" >&2
      return 1
    fi
    local connections; connections=$(_webhook_read_connections)
    local existing; existing=$(printf '%s' "$connections" | jq -r --arg n "$conn_name" '.[] | select(.name == $n) | .name' 2>/dev/null)
    if [ -z "$existing" ]; then
      echo "Error: connection '$conn_name' not found" >&2
      return 1
    fi
    local updated; updated=$(printf '%s' "$connections" | jq --arg n "$conn_name" --arg t "$set_token" \
      '[.[] | if .name == $n then .github_token = $t else . end]')
    _webhook_write_connections "$updated"
    echo "Set github_token=<redacted> in connection '$conn_name'"
    return 0
  fi

  if [ -n "$set_bind" ]; then
    _webhook_json_set_key "$WEBHOOK_JSON" "bind" "$set_bind"
    echo "Set bind=$set_bind"
  fi

  if [ -n "$set_port" ]; then
    _webhook_json_set_key "$WEBHOOK_JSON" "port" "$set_port" "--argjson"
    echo "Set port=$set_port"
  fi

  if [ -n "$set_bind" ] || [ -n "$set_port" ]; then
    return 0
  fi

  case "${subcmd:-}" in
    status) _gh_webhook_listener_status ;;
    "")
      echo "Usage: claude-pod gh-webhook-listener [status|--add-connection|--set-token|--set-bind|--set-port]" >&2
      echo "Run 'claude-pod gh-webhook-listener --help' for more information." >&2
      return 1
      ;;
    *)
      echo "Error: unknown subcommand '$subcmd'" >&2
      return 1
      ;;
  esac
}

# =========================================================================
# Source-only guard: if sourced by tests, stop here
# =========================================================================
if [ "$__CLAUDE_POD_SOURCE_ONLY" = "1" ]; then
  return 0 2>/dev/null || true
fi

# =========================================================================
# Main execution
# =========================================================================

# Verify installation (or auto-derive APP_DIR when running from a dev checkout
# so `bin/claude-pod` can be invoked against a test CONFIG_DIR).
if [ -f "$CONFIG_DIR/config.sh" ]; then
  # Load global config (APP_DIR, PLATFORM, optionally DEFAULT_WORKSPACE)
  # shellcheck source=/dev/null
  source "$CONFIG_DIR/config.sh"
else
  # Dev-checkout fallback: infer APP_DIR from the script path if this looks
  # like a git checkout. Used by test harnesses that construct a synthetic
  # CONFIG_DIR without running install.sh.
  _SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  _CANDIDATE_APP_DIR="$(cd "$_SELF_DIR/.." && pwd)"
  if [ -d "$_CANDIDATE_APP_DIR/.git" ] || [ -f "$_CANDIDATE_APP_DIR/install.sh" ]; then
    APP_DIR="$_CANDIDATE_APP_DIR"
    PLATFORM="${PLATFORM:-linux}"
  else
    echo "ERROR: claude-pod not installed. Run install.sh first." >&2
    exit 1
  fi
  unset _SELF_DIR _CANDIDATE_APP_DIR
fi

# Parse args; reject removed flags with helpful messages
ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile)
      if [[ " ${ARGS[*]} " == *" gh-webhook-listener "* ]] || [[ " ${ARGS[*]} " == *" list "* ]]; then
        # --profile is valid for gh-webhook-listener and for `list --profile`
        # (list --profile shows configured profiles instead of running instances)
        ARGS+=("$1"); shift
      else
        _profile_hint="${2:-<name>}"
        echo "ERROR: --profile flag removed. Use: claude-pod profile create $_profile_hint" >&2
        exit 1
      fi ;;
    --instance)
      echo "ERROR: --instance is no longer supported. Use: claude-pod profile create <name>" >&2
      exit 1 ;;
    *) ARGS+=("$1"); shift ;;
  esac
done

FIRST_ARG="${ARGS[0]:-}"

# Superuser mode (allowed for most commands). Skip config load for commands
# that don't need a merged workspace or that manage their own profile resolution.
case "$FIRST_ARG" in
  list|help|--help|-h|replay|reap|spawn|update|upgrade|status|bootstrap-docs|gh-webhook-listener|start|stop|remove|logs|profile|uninstall)
    : # skip superuser load
    ;;
  *)
    load_superuser_config
    ;;
esac

# Parse log flags
parse_log_flags "${ARGS[@]}"

# Use first non-log-flag argument as command
CMD="${REMAINING_ARGS[0]:-}"

case "$CMD" in
  stop)
    if [ -n "${REMAINING_ARGS[1]:-}" ]; then
      require_profile_arg
      docker compose down
    else
      # No profile name given: stop all configured profiles.
      shopt -s nullglob
      _stop_count=0
      _stop_failed=0
      for _pdir in "$CONFIG_DIR/profiles"/*/; do
        _pname=$(basename "$_pdir")
        echo "Stopping profile: $_pname"
        if ( load_profile_config "$_pname" && docker compose down ); then
          _stop_count=$((_stop_count + 1))
        else
          echo "warning: failed to stop profile $_pname" >&2
          _stop_failed=$((_stop_failed + 1))
        fi
      done
      shopt -u nullglob
      echo "Stopped $_stop_count profile(s)${_stop_failed:+, $_stop_failed failed}."
    fi
    ;;
  status)
    if [ -n "${REMAINING_ARGS[1]:-}" ]; then
      require_profile_arg
      docker compose ps
      if docker compose ps --status running --format '{{.Service}}' | grep -q '^claude$'; then
        echo ""
        echo "Claude Code version: $(docker compose exec -T claude claude --version 2>/dev/null || echo 'unknown')"
      fi
    else
      # No profile: show all claude-pod containers across all profiles/spawns.
      # Container names start with the compose project name (claude-<profile>,
      # claude-superuser, cs-<profile>-<uuid>).
      docker ps --format "table {{.Names}}\t{{.Image}}\t{{.Command}}\t{{.CreatedAt}}\t{{.Status}}\t{{.Ports}}" | \
        awk 'NR==1 { print; next } /^(claude-|cs-)/ { print }'
    fi
    ;;
  update)
    echo "Pulling latest changes..."
    sudo git -C "$APP_DIR" pull
    # Migrate profile layout to the file-based tasks/ + system_prompts/ model
    # BEFORE replacing the binary, so the new CLI finds migrated profiles.
    _migrate_script="$APP_DIR/scripts/migrate-profile-prompts.sh"
    if [ -x "$_migrate_script" ]; then
      echo "Migrating profile prompts..."
      CONFIG_DIR="$CONFIG_DIR" bash "$_migrate_script" || \
        echo "WARNING: migrate-profile-prompts.sh failed (continuing)"
    fi
    # Update CLI wrapper if source changed (do this before rebuilding images
    # so the new binary is in place if the user re-runs after a partial failure)
    CLI_INSTALLED="$(command -v claude-pod)"
    CLI_SOURCE="$APP_DIR/bin/claude-pod"
    if [ -f "$CLI_SOURCE" ] && ! diff -q "$CLI_SOURCE" "$CLI_INSTALLED" >/dev/null 2>&1; then
      echo "CLI wrapper changed, updating..."
      if [ -w "$(dirname "$CLI_INSTALLED")" ]; then
        cp "$CLI_SOURCE" "$CLI_INSTALLED"
        chmod 755 "$CLI_INSTALLED"
      elif command -v sudo >/dev/null 2>&1; then
        sudo cp "$CLI_SOURCE" "$CLI_INSTALLED"
        sudo chmod 755 "$CLI_INSTALLED"
      else
        echo "WARNING: Could not update CLI at $CLI_INSTALLED (no write access)"
        echo "Run manually: sudo cp $CLI_SOURCE $CLI_INSTALLED"
      fi
    fi
    echo "Rebuilding images for all profiles..."
    shopt -s nullglob
    _update_count=0
    for _pdir in "$CONFIG_DIR/profiles"/*/; do
      _pname=$(basename "$_pdir")
      echo "  [$_pname] rebuilding..."
      COMPOSE_PROJECT_NAME="claude-$_pname" \
        docker compose -f "$APP_DIR/docker-compose.yml" build claude proxy validator
      _update_count=$((_update_count + 1))
    done
    shopt -u nullglob
    echo "  [superuser] rebuilding..."
    COMPOSE_PROJECT_NAME="claude-superuser" \
      docker compose -f "$APP_DIR/docker-compose.yml" build claude proxy validator
    if [ "$_update_count" -eq 0 ]; then
      echo "  [default] rebuilding..."
      docker compose -f "$APP_DIR/docker-compose.yml" build claude proxy validator
    fi
    echo ""
    echo "Update complete. ${_update_count} profile(s) + superuser rebuilt."
    exit 0
    ;;
  upgrade)
    echo "Upgrading Claude Code for all profiles..."
    shopt -s nullglob
    _upgrade_count=0
    for _pdir in "$CONFIG_DIR/profiles"/*/; do
      _pname=$(basename "$_pdir")
      echo "  [$_pname] upgrading..."
      COMPOSE_PROJECT_NAME="claude-$_pname" \
        docker compose -f "$APP_DIR/docker-compose.yml" build --no-cache --pull claude
      _upgrade_count=$((_upgrade_count + 1))
    done
    shopt -u nullglob
    if [ "$_upgrade_count" -eq 0 ]; then
      echo "  No profiles found; rebuilding default image..."
      docker compose -f "$APP_DIR/docker-compose.yml" build --no-cache --pull claude
    fi
    echo ""
    echo "Upgrade complete. ${_upgrade_count} profile image(s) upgraded."
    ;;
  list)
    # Issue #72: bare `list` shows running instances; `list --profile` shows
    # configured profiles (preserves old behavior under the new flag).
    _list_show_profile=0
    for _larg in "${REMAINING_ARGS[@]:1}"; do
      [ "$_larg" = "--profile" ] && _list_show_profile=1
    done
    if [ "$_list_show_profile" -eq 1 ]; then
      list_profiles
    else
      list_instances
    fi
    ;;
  remove)
    require_profile_arg
    echo "This will stop containers and delete config for profile '$PROFILE'."
    read -rp "Are you sure? [y/N]: " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
      echo "Cancelled."; exit 0
    fi
    docker compose down --remove-orphans 2>/dev/null || true
    rm -rf "$CONFIG_DIR/profiles/$PROFILE"
    echo "Profile '$PROFILE' removed."
    echo "Note: Docker volumes (workspace, validator-db) are preserved."
    echo "Run 'docker volume ls | grep claude-${PROFILE}' to see them."
    ;;
  logs)
    if [ -z "${REMAINING_ARGS[1]:-}" ]; then
      echo "ERROR: profile name required" >&2
      echo "Usage: claude-pod logs <name> [hook|anthropic|iptables|clear]" >&2
      exit 1
    fi
    require_profile_arg
    LOG_SVC="${REMAINING_ARGS[2]:-}"
    case "$LOG_SVC" in
      hook)       docker compose exec -T claude tail -f /var/log/claude-pod/hook.jsonl ;;
      anthropic)  docker compose exec -T proxy tail -f /var/log/claude-pod/anthropic.jsonl ;;
      iptables)   docker compose exec -T validator tail -f /var/log/claude-pod/iptables.jsonl ;;
      clear)
        docker compose exec -T claude rm -f /var/log/claude-pod/hook.jsonl 2>/dev/null || true
        docker compose exec -T proxy rm -f /var/log/claude-pod/anthropic.jsonl 2>/dev/null || true
        docker compose exec -T validator rm -f /var/log/claude-pod/iptables.jsonl 2>/dev/null || true
        echo "Logs cleared for profile '$PROFILE'."
        ;;
      "")
        docker compose exec -T claude tail -f /var/log/claude-pod/hook.jsonl &
        docker compose exec -T proxy tail -f /var/log/claude-pod/anthropic.jsonl &
        docker compose exec -T validator tail -f /var/log/claude-pod/iptables.jsonl &
        wait
        ;;
      *)
        echo "Unknown log service: $LOG_SVC"
        echo "Usage: claude-pod logs <name> [hook|anthropic|iptables|clear]"
        exit 1
        ;;
    esac
    ;;
  profile)
    cmd_profile "${REMAINING_ARGS[@]:1}"
    ;;
  help|--help|-h)
    echo "Usage: claude-pod <command> [args] [log flags]"
    echo ""
    echo "Profile:"
    echo "  profile create <name>  Create a profile interactively, then exit"
    echo "  profile <name>         Show profile info (workspace, secrets, status)"
    echo "  profile <name> secret list"
    echo "  profile <name> secret add <KEY> [<value>] [--redacted <TOKEN>] [--domains d1,d2,...]"
    echo "  profile <name> secret remove <KEY>"
    echo ""
    echo "Session:"
    echo "  start <name>       Start an interactive Claude Code session"
    echo "  spawn <name>       Run a headless Claude Code session"
    echo "  replay <name> <delivery-id>  Re-run a persisted webhook delivery"
    echo ""
    echo "Management:"
    echo "  status [name]      Container status (all profiles if no name given)"
    echo "  stop [name]        Stop containers (all profiles if no name given)"
    echo "  remove <name>      Remove profile config and stop containers"
    echo "  logs <name>        Tail log files [hook|anthropic|iptables|clear]"
    echo "  list               List running instances (interactive + headless)"
    echo "  list --profile     List configured profiles and their status"
    echo ""
    echo "System:"
    echo "  update             Pull latest claude-pod, rebuild all images"
    echo "  upgrade            Upgrade Claude Code to latest version"
    echo "  reap               Clean up orphaned spawn containers and stale event files"
    echo "  bootstrap-docs     Scaffold project docs in configured remote repo"
    echo "  gh-webhook-listener   Configure and inspect the webhook listener service"
    echo "  uninstall          Remove claude-pod (binary, services, config dir)"
    echo "  uninstall --dry-run        Preview what would be removed"
    echo "  uninstall --keep-data      Remove binaries/services, preserve ~/.claude-pod/"
    echo "  uninstall --remove-images  Also remove Docker images"
    echo "  help               Show this help message"
    echo ""
    echo "Spawn flags:"
    echo "  --event '<json>'       Event payload as JSON string"
    echo "  --event-file <path>    Event payload from file"
    echo "  --prompt-template <n>  Override automatic template resolution"
    echo "  --dry-run              Show resolved prompt without executing"
    echo ""
    echo "Log flags (append to any command):"
    echo "  log:hook       Hook script decisions"
    echo "  log:anthropic  Proxy metadata"
    echo "  log:bodies     Proxy full request/response bodies"
    echo "  log:iptables   Validator/iptables events"
    echo "  log:all        All logging (metadata, no bodies)"
    echo ""
    echo "Profile names: lowercase alphanumeric and hyphens, max 63 characters."
    echo "Run without arguments for superuser mode (merged access to all profiles)."
    ;;
  bootstrap-docs)
    cmd_bootstrap_docs "${REMAINING_ARGS[@]:1}"
    ;;
  gh-webhook-listener)
    cmd_gh_webhook_listener "${REMAINING_ARGS[@]:1}"
    ;;
  spawn)
    do_spawn
    ;;
  replay)
    do_replay
    ;;
  reap)
    # Drop the "reap" literal so only the remaining flags (if any) go to do_reap.
    do_reap "${REMAINING_ARGS[@]:1}"
    ;;
  uninstall)
    _uninstall_script="$APP_DIR/uninstall.sh"
    if [ ! -f "$_uninstall_script" ]; then
      echo "ERROR: uninstall.sh not found at $_uninstall_script" >&2
      echo "Run 'claude-pod update' first, or run uninstall.sh directly from the source tree." >&2
      exit 1
    fi
    bash "$_uninstall_script" "${REMAINING_ARGS[@]:1}"
    ;;
  start)
    require_profile_arg
    # Issue #72: set Docker labels for instance tracking before docker compose up.
    # These are consumed by the labels section in docker-compose.yml and allow
    # `claude-pod list` to discover running instances via docker ps label filter.
    export CLAUDE_POD_LABEL_PROFILE="${PROFILE:-}"
    export CLAUDE_POD_LABEL_TYPE="interactive"
    export CLAUDE_POD_LABEL_EVENT_TYPE=""
    export CLAUDE_POD_LABEL_EVENT_ID=""
    export CLAUDE_POD_LABEL_STARTED_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    cleanup_containers
    docker compose up -d
    _interactive_args=(--dangerously-skip-permissions)
    if [ -n "${CLAUDE_POD_SYSTEM_PROMPT:-}" ]; then
      _interactive_args+=(--system-prompt "$CLAUDE_POD_SYSTEM_PROMPT")
    fi
    docker compose exec -it claude claude "${_interactive_args[@]}"
    docker compose down
    ;;
  *)
    if [ -n "$CMD" ]; then
      echo "ERROR: Unknown command '$CMD'" >&2
      echo "Run: claude-pod help" >&2
      exit 1
    fi
    # No command, no --profile: superuser interactive session (merged all profiles)
    # Issue #72: set Docker labels for instance tracking (superuser mode).
    export CLAUDE_POD_LABEL_PROFILE="superuser"
    export CLAUDE_POD_LABEL_TYPE="interactive"
    export CLAUDE_POD_LABEL_EVENT_TYPE=""
    export CLAUDE_POD_LABEL_EVENT_ID=""
    export CLAUDE_POD_LABEL_STARTED_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    cleanup_containers
    docker compose up -d
    _interactive_args=(--dangerously-skip-permissions)
    if [ -n "${CLAUDE_POD_SYSTEM_PROMPT:-}" ]; then
      _interactive_args+=(--system-prompt "$CLAUDE_POD_SYSTEM_PROMPT")
    fi
    docker compose exec -it claude claude "${_interactive_args[@]}"
    docker compose down
    ;;
esac
